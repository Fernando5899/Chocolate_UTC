// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ¡NADA DE URL AQUÍ!
}

// --- MÓDULO: CATÁLOGO DEL MUSEO ---

model Categoria {
  id          String      @id @default(uuid())
  nombre      String      @unique
  descripcion String?
  chocolates  Chocolate[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Chocolate {
  id          String  @id @default(uuid())
  nombre      String
  descripcion String
  precio      Decimal @db.Decimal(10, 2)
  stock       Int     @default(0)
  imagenUrl   String?

  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  detalleOrdens DetalleOrden[]
}

// --- MÓDULO: SEGURIDAD Y PERFIL DE USUARIO (Auth.js) ---

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // 🆕 CAMPOS DE PERFIL PARA ENVÍOS NACIONALES
  telefono     String?
  direccion    String?
  ciudad       String?
  codigoPostal String?
  estado       String? // "CDMX" o "Edomex"

  accounts Account[]
  sessions Session[]
  ordenes  Orden[] // Relación: Un usuario puede ver su historial de compras
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- MÓDULO: LOGÍSTICA Y VENTAS ---

model Orden {
  id            String         @id @default(cuid())
  fecha         DateTime       @default(now())
  clienteNombre String
  estadoEnvio   String // "CDMX" o "Edomex"
  direccion     String
  codigoPostal  String
  total         Float
  detalles      DetalleOrden[]

  // 🔗 VINCULACIÓN OPCIONAL CON USUARIO REGISTRADO
  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

model DetalleOrden {
  id          String    @id @default(cuid())
  ordenId     String
  orden       Orden     @relation(fields: [ordenId], references: [id])
  chocolateId String
  chocolate   Chocolate @relation(fields: [chocolateId], references: [id])
  cantidad    Int
  precioUnit  Float
}

// --- MÓDULO: EXPOSICIONES Y MUSEO ---

// --- MÓDULO: EXPOSICIONES Y MUSEO ---

model Sala {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String   @db.Text
  imagenUrl   String   // Esta es la portada
  galeria     String[] @default([]) // AQUI ESTÁN LAS 8 IMÁGENES
  historia    String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
