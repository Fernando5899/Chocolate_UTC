---
---
<button id="chatbot-toggle" class="fixed bottom-6 right-6 w-14 h-14 bg-stone-900 dark:bg-white text-white dark:text-black rounded-full shadow-2xl flex items-center justify-center text-2xl hover:scale-110 transition-transform z-[100] border-2 border-stone-700 dark:border-stone-300">
    💬
</button>

<div id="chatbot-window" class="fixed bottom-24 right-6 w-[350px] h-[500px] bg-white dark:bg-[#110e0d] rounded-3xl shadow-2xl border border-stone-200 dark:border-stone-800 flex flex-col hidden z-[100] overflow-hidden transition-all duration-300 transform origin-bottom-right">

    <div class="bg-stone-900 dark:bg-stone-800 p-4 text-center border-b border-orange-600">
        <h3 class="text-white font-serif italic text-lg">Curador Virtual</h3>
        <p class="text-orange-500 text-[9px] uppercase tracking-widest font-black">Asistente con IA</p>
    </div>

    <div id="chatbot-messages" class="flex-grow p-4 overflow-y-auto bg-stone-50 dark:bg-[#0c0a09] space-y-4 text-sm font-sans">
        <div class="flex justify-start">
            <div class="bg-stone-200 dark:bg-stone-800 text-stone-900 dark:text-white px-4 py-3 rounded-2xl rounded-tl-none max-w-[85%] shadow-sm">
                ¡Hola! Soy el Curador del Museo. ¿En qué te puedo ayudar hoy con tu expedición por el mundo del chocolate?
            </div>
        </div>
    </div>

    <div class="p-4 bg-white dark:bg-[#110e0d] border-t border-stone-200 dark:border-stone-800">
        <form id="chatbot-form" class="flex gap-2">
            <input type="text" id="chatbot-input" placeholder="Pregunta sobre el museo..." class="flex-grow bg-stone-100 dark:bg-stone-900 text-stone-900 dark:text-white px-4 py-3 rounded-full outline-none focus:border-orange-500 border border-transparent transition-colors text-xs" autocomplete="off" />
            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white w-10 h-10 rounded-full flex items-center justify-center transition-colors shadow-md disabled:opacity-50" id="chatbot-submit">
                ↑
            </button>
        </form>
    </div>
</div>

<script>
    const toggleBtn = document.getElementById('chatbot-toggle');
    const chatWindow = document.getElementById('chatbot-window');
    const form = document.getElementById('chatbot-form');
    const input = document.getElementById('chatbot-input') as HTMLInputElement;
    const messagesContainer = document.getElementById('chatbot-messages');
    const submitBtn = document.getElementById('chatbot-submit') as HTMLButtonElement;

    // Abrir/Cerrar chat
    toggleBtn?.addEventListener('click', () => {
        chatWindow?.classList.toggle('hidden');
        if (!chatWindow?.classList.contains('hidden')) {
            input?.focus();
        }
    });

    // Función para añadir burbujas de texto al chat
    function addMessage(text: string, isUser: boolean) {
        if (!messagesContainer) return;

        const div = document.createElement('div');
        div.className = `flex ${isUser ? 'justify-end' : 'justify-start'}`;

        const bubble = document.createElement('div');
        bubble.className = `px-4 py-3 rounded-2xl max-w-[85%] shadow-sm text-sm ${
            isUser
                ? 'bg-orange-600 text-white rounded-tr-none'
                : 'bg-stone-200 dark:bg-stone-800 text-stone-900 dark:text-white rounded-tl-none'
        }`;
        bubble.textContent = text;

        div.appendChild(bubble);
        messagesContainer.appendChild(div);

        // Auto-scroll hacia abajo
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // Enviar mensaje a la API
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = input.value.trim();
        if (!text) return;

        // Mostrar mensaje del usuario
        addMessage(text, true);
        input.value = '';
        submitBtn.disabled = true;

        // Mostrar indicador de "Escribiendo..."
        const typingId = 'typing-' + Date.now();
        if (messagesContainer) {
            messagesContainer.insertAdjacentHTML('beforeend', `
                <div id="${typingId}" class="flex justify-start">
                    <div class="bg-stone-200 dark:bg-stone-800 text-stone-500 dark:text-stone-400 px-4 py-3 rounded-2xl rounded-tl-none shadow-sm text-xs italic">
                        El curador está pensando...
                    </div>
                </div>
            `);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mensaje: text })
            });

            const data = await response.json();

            // Quitar el "Escribiendo..."
            document.getElementById(typingId)?.remove();

            if (data.respuesta) {
                addMessage(data.respuesta, false);
            } else {
                addMessage("Lo siento, tuve un problema procesando tu petición.", false);
            }
        } catch (error) {
            document.getElementById(typingId)?.remove();
            addMessage("Hubo un error de conexión.", false);
        } finally {
            submitBtn.disabled = false;
            input.focus();
        }
    });
</script>