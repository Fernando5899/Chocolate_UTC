---
interface Props { title: string; }
import '../styles/global.css';
import { getSession } from 'auth-astro/server';
import { SignOut } from 'auth-astro/components';
import Chatbot from '../components/Chatbot.astro';

const { title } = Astro.props;
const session = await getSession(Astro.request);
const isAdmin = session?.user?.email === 'fernando.jose.reynosa@gmail.com';
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portal Institucional del Museo de Chocolate" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <title>{title}</title>

    <script is:inline>
        const theme = localStorage.getItem('theme') || 'dark';
        if (theme === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>

<body class="bg-stone-50 text-stone-900 dark:bg-[#0c0a09] dark:text-stone-100 transition-colors duration-500 min-h-screen flex flex-col font-sans selection:bg-orange-500/30 relative">

<nav class="bg-white/80 dark:bg-black/80 backdrop-blur-md border-b border-stone-200 dark:border-stone-800 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-4 md:py-6 flex justify-between items-center">

        <a href="/" class="flex flex-col z-50 group">
            <span class="text-xl md:text-2xl font-serif italic font-black tracking-tight leading-none text-stone-900 dark:text-white group-hover:text-orange-600 transition-colors">
                Museo de Chocolate
            </span>
            <span class="text-[9px] md:text-xs text-stone-500 uppercase tracking-[0.4em] mt-1 font-bold">Cultura y Tradición</span>
        </a>

        <div class="hidden md:flex items-center gap-8 uppercase text-[10px] tracking-[0.2em] font-extrabold">
            <a href="/" class="text-stone-600 dark:text-stone-300 hover:text-orange-500 transition-all">Inicio</a>
            <a href="/exposiciones" class="text-stone-600 dark:text-stone-300 hover:text-orange-500 transition-all">Exposiciones</a>
            <a href="/tienda/chocolates" class="text-stone-600 dark:text-stone-300 hover:text-orange-500 transition-all">Chocolates</a>
            <a href="/visita/boletos" class="text-stone-600 dark:text-stone-300 hover:text-orange-500 transition-all">Boletos</a>
            <a href="/visita/horarios" class="text-stone-600 dark:text-stone-300 hover:text-orange-500 transition-all">Horarios</a>

            <a href="/tienda/carrito" class="flex items-center gap-2 text-stone-600 dark:text-stone-300 hover:text-orange-500 transition-all group">
                Carrito
                <span class="contador-carrito inline-flex items-center justify-center h-6 min-w-6 px-2 border border-stone-300 dark:border-stone-700 rounded-full text-[10px] font-mono leading-none transition-all group-hover:border-orange-500">0</span>
            </a>

            <button class="theme-toggle p-2 rounded-lg border border-stone-300 dark:border-stone-800 hover:border-orange-500 transition-all cursor-pointer bg-transparent">
                <span class="theme-icon text-stone-600 dark:text-orange-400 text-xl leading-none"></span>
            </button>

            <div class="w-px h-6 bg-stone-300 dark:bg-stone-800"></div>

            {session ? (
                    <div class="flex items-center gap-6">
                        {isAdmin && (
                                <a href="/admin/dashboard" class="text-orange-600 dark:text-orange-500 hover:text-orange-400 transition-colors flex items-center gap-1 font-black uppercase tracking-widest text-[9px]">
                                    <span>⚙️</span> Admin
                                </a>
                        )}
                        <a href="/cuenta/perfil" class="text-stone-600 dark:text-stone-400 hover:text-orange-500 transition-colors">Perfil</a>

                        <SignOut class="text-stone-500 cursor-pointer opacity-70 hover:opacity-100 hover:text-orange-500 uppercase text-[10px] tracking-widest font-black transition-all bg-transparent border-none p-0">
                            SALIR
                        </SignOut>
                    </div>
            ) : (
                    <a href="/cuenta/login" class="text-stone-500 hover:text-orange-500 uppercase text-[10px] tracking-widest font-black transition-all">Ingresar</a>
            )}
        </div>

        <div class="md:hidden flex items-center gap-2 z-50">
            <button class="theme-toggle p-2 rounded-lg border border-transparent transition-all cursor-pointer bg-transparent">
                <span class="theme-icon text-stone-600 dark:text-orange-400 text-xl leading-none"></span>
            </button>
            <button id="btn-menu-movil" class="p-2 text-stone-900 dark:text-white focus:outline-none bg-transparent border-none">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path id="icon-abrir" class="block" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    <path id="icon-cerrar" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <div id="menu-movil" class="hidden md:hidden absolute top-full left-0 w-full bg-white dark:bg-[#0c0a09] border-b border-stone-200 dark:border-stone-800 shadow-2xl transition-all duration-300 z-40">
        <div class="px-8 py-8 flex flex-col gap-6 uppercase text-xs font-black tracking-[0.2em]">
            <a href="/" class="text-stone-600 dark:text-stone-300 hover:text-orange-500">Inicio</a>
            <a href="/exposiciones" class="text-stone-600 dark:text-stone-300 hover:text-orange-500">Exposiciones</a>
            <a href="/tienda/chocolates" class="text-stone-600 dark:text-stone-300 hover:text-orange-500">Chocolates</a>
            <a href="/visita/boletos" class="text-stone-600 dark:text-stone-300 hover:text-orange-500">Boletos</a>
            <a href="/visita/horarios" class="text-stone-600 dark:text-stone-300 hover:text-orange-500">Horarios</a>

            <a href="/tienda/carrito" class="flex justify-between items-center text-stone-600 dark:text-stone-300 hover:text-orange-500 border-t border-stone-200 dark:border-stone-800 pt-6">
                Carrito
                <span class="contador-carrito inline-flex items-center justify-center h-6 min-w-6 px-2 bg-stone-900 dark:bg-white text-white dark:text-black rounded-full text-[11px] font-mono leading-none">0</span>
            </a>

            <div class="border-t border-stone-200 dark:border-stone-800 pt-6 flex flex-col gap-6">
                {session ? (
                        <>
                            {isAdmin && (
                                    <a href="/admin/dashboard" class="text-orange-600 dark:text-orange-500 flex items-center gap-2">
                                        <span>⚙️</span> Panel Admin
                                    </a>
                            )}
                            <a href="/cuenta/perfil" class="text-stone-600 dark:text-stone-300 hover:text-orange-500">Mi Perfil</a>
                            <SignOut class="text-left text-stone-500 hover:text-orange-500 uppercase tracking-widest font-black bg-transparent border-none p-0">
                                CERRAR SESIÓN
                            </SignOut>
                        </>
                ) : (
                        <a href="/cuenta/login" class="text-center text-orange-600 dark:text-orange-500 border border-orange-600 dark:border-orange-500 py-4 rounded-full w-full font-black">Iniciar Sesión</a>
                )}
            </div>
        </div>
    </div>
</nav>

<main class="grow flex flex-col">
    <slot />
</main>

<footer class="bg-white dark:bg-black text-stone-500 py-24 border-t border-stone-200 dark:border-stone-900 mt-auto transition-colors duration-500">
    <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-3 gap-16 text-center md:text-left">
        <div>
            <h4 class="text-stone-900 dark:text-white font-serif italic font-black text-xl mb-6">El Museo</h4>
            <p class="text-base leading-relaxed font-serif italic opacity-80">Dedicado a la preservación de la historia del cacao en México.</p>
        </div>
        <div>
            <h4 class="text-stone-900 dark:text-white font-serif italic font-black text-xl mb-6">Ubicación</h4>
            <p class="text-base font-serif italic text-stone-600 dark:text-stone-400">Calle Milan 45, Juárez, CDMX</p>
        </div>
        <div class="md:text-right flex flex-col md:items-end">
            <p class="text-[10px] uppercase tracking-[0.4em] font-black text-stone-900 dark:text-white mb-4">© {new Date().getFullYear()} Museo de Chocolate</p>
            <p class="text-sm italic font-serif text-orange-600 dark:text-orange-500 drop-shadow-sm">Diseñado para la posteridad</p>
        </div>
    </div>
</footer>

<Chatbot />

<div id="fnaf-easteregg" class="fixed inset-0 hidden bg-black/95 items-center justify-center flex-col cursor-pointer p-4 transition-opacity duration-300" style="z-index: 9999;">

    <div class="w-full max-w-4xl aspect-video bg-black rounded-lg overflow-hidden shadow-2xl relative flex items-center justify-center">
        <video id="fnaf-video"
               class="w-full h-full object-contain"
               preload="auto"
               playsinline>
            <source src="/Fnaf3.mp4" type="video/mp4" />
        </video>
    </div>

    <p class="mt-8 text-white/40 text-[10px] font-mono tracking-widest uppercase animate-pulse">
        [ Haz clic para saltar ]
    </p>
</div>

<script>
    import { carrito } from '../store/carrito';

    // 1. MENÚ MÓVIL
    const btnMenu = document.getElementById('btn-menu-movil');
    const menuMovil = document.getElementById('menu-movil');
    const iconAbrir = document.getElementById('icon-abrir');
    const iconCerrar = document.getElementById('icon-cerrar');

    btnMenu?.addEventListener('click', () => {
        menuMovil?.classList.toggle('hidden');
        iconAbrir?.classList.toggle('hidden');
        iconCerrar?.classList.toggle('hidden');
    });

    // 2. TEMA
    const botonesTema = document.querySelectorAll('.theme-toggle');
    const iconosTema = document.querySelectorAll('.theme-icon');
    const html = document.documentElement;

    const updateIcons = () => {
        iconosTema.forEach(icon => {
            icon.textContent = html.classList.contains('dark') ? '☀️' : '🌙';
        });
    };
    updateIcons();

    botonesTema.forEach(btn => {
        btn.addEventListener('click', () => {
            html.classList.toggle('dark');
            localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
            updateIcons();
        });
    });

    // 3. CARRITO
    const contadores = document.querySelectorAll('.contador-carrito');
    carrito.subscribe((items) => {
        const totalItems = Object.values(items).reduce((suma, item) => suma + item.cantidad, 0);

        contadores.forEach(contador => {
            contador.textContent = totalItems > 99 ? '99+' : totalItems.toString();

            if (totalItems > 0) {
                contador.classList.add('border-orange-500', 'text-orange-600', 'dark:text-orange-500');
            } else {
                contador.classList.remove('border-orange-500', 'text-orange-600', 'dark:text-orange-500');
            }
        });
    });

    // 4. LIMPIEZA AL SALIR
    const botonesSalir = document.querySelectorAll('[data-auth-signout]');
    botonesSalir.forEach(btn => {
        btn.addEventListener('click', () => {
            carrito.set({});
        });
    });

    // 5. LÓGICA DEL EASTER EGG (FNAF)
    document.addEventListener('DOMContentLoaded', () => {
        const navLinks = document.querySelectorAll('nav a');
        const overlay = document.getElementById('fnaf-easteregg');
        const video = document.getElementById('fnaf-video') as HTMLVideoElement;

        const PROBABILIDAD = 0.1;

        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                const url = link.getAttribute('href');

                if (!url || url.startsWith('http') || url.startsWith('#')) return;

                if (Math.random() <= PROBABILIDAD) {
                    e.preventDefault();

                    overlay?.classList.remove('hidden');
                    overlay?.classList.add('flex');

                    video.currentTime = 0;
                    video.play().catch(() => {
                        window.location.href = url;
                    });

                    video.onended = () => {
                        window.location.href = url;
                    };

                    overlay?.addEventListener('click', () => {
                        window.location.href = url;
                    });
                }
            });
        });
    });
</script>
</body>
</html>