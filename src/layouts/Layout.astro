---
interface Props {
    title: string;
}

import '../styles/global.css';

// 1. Importamos las herramientas de Auth.js
import { getSession } from 'auth-astro/server';
import { SignOut } from 'auth-astro/components';

const { title } = Astro.props;

// 2. Le preguntamos al servidor si hay alguien con sesión activa
const session = await getSession(Astro.request);
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="description" content="Catálogo virtual del Museo de Chocolate" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
</head>
<body class="bg-orange-50 text-stone-800 font-sans antialiased min-h-screen flex flex-col">
<nav class="bg-stone-900 text-orange-50 py-4 shadow-md">
    <div class="max-w-5xl mx-auto px-6 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold tracking-wider hover:text-orange-300 transition-colors">
            🍫 Museo de Chocolate
        </a>

        <div class="space-x-4 flex items-center">
            <a href="/" class="hover:text-orange-300 transition-colors">Inicio</a>
            <a href="#" class="hover:text-orange-300 transition-colors">Catálogo</a>

            {/* 3. Lógica Dinámica: Si hay sesión, mostramos controles de Admin */}
            {session ? (
                    <>
                        <a href="/admin" class="text-orange-400 font-semibold hover:text-orange-300 transition-colors">
                            Panel Admin
                        </a>
                        <SignOut class="bg-stone-800 hover:bg-stone-700 text-sm px-4 py-2 rounded-lg transition-colors border border-stone-700 cursor-pointer">
                            Cerrar Sesión
                        </SignOut>
                    </>
            ) : (
                /* Si NO hay sesión, mostramos el acceso genérico */
                    <a href="/cuenta/login" class="text-stone-300 hover:text-white border border-stone-600 hover:border-orange-400 text-sm px-4 py-2 rounded-lg transition-all">
                        Login
                    </a>
            )}
        </div>
    </div>
</nav>

<main class="max-w-5xl mx-auto px-6 py-8 flex-grow w-full">
    <slot />
</main>

<footer class="text-center py-6 text-stone-500 text-sm mt-auto border-t border-stone-200">
    &copy; {new Date().getFullYear()} Museo de Chocolate. Todos los derechos reservados.
</footer>
</body>
</html>