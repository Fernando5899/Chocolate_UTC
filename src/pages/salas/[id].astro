---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

const { id } = Astro.params;
const sala = await prisma.sala.findUnique({ where: { id } });
if (!sala) return Astro.redirect('/404');

const galeriaSegura = Array.isArray(sala.galeria) ? sala.galeria as string[] : [];
---

<Layout title={`${sala.nombre} | Museo de Chocolate`}>
    <div class="relative w-full h-[60vh] md:h-[75vh] bg-stone-200 dark:bg-stone-900 flex items-end overflow-hidden">
        <img src={sala.imagenUrl} alt={`Portada de la sala ${sala.nombre}`} class="absolute inset-0 w-full h-full object-cover opacity-80 dark:opacity-50 scale-105" />
        
        <div class="absolute inset-0 bg-gradient-to-t from-stone-50 via-stone-50/40 to-transparent dark:from-[#0c0a09] dark:via-[#0c0a09]/60"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-8 pb-20 w-full">
            
            <a href="/exposiciones" class="inline-flex items-center gap-3 text-[10px] font-bold uppercase tracking-widest text-stone-900 dark:text-white bg-white/60 dark:bg-black/50 backdrop-blur-md px-6 py-3 rounded-full hover:bg-orange-600 hover:text-white dark:hover:bg-orange-600 transition-all duration-300 border border-stone-300 dark:border-stone-700 hover:border-orange-600 dark:hover:border-orange-600 mb-6 w-fit group shadow-lg">
                <span class="text-lg leading-none group-hover:-translate-x-1 transition-transform">←</span> 
                Volver a las Exposiciones
            </a>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif italic font-black text-stone-900 dark:text-white leading-tight drop-shadow-md max-w-4xl">
                {sala.nombre}
            </h1>
        </div>
    </div>

    {sala.historia && (
            <section class="max-w-4xl mx-auto py-24 px-8">
                <div class="flex items-center gap-4 mb-12 opacity-50">
                    <div class="h-px bg-stone-300 dark:bg-stone-800 grow"></div>
                    <span class="text-[10px] font-bold uppercase tracking-widest">Contexto Histórico</span>
                    <div class="h-px bg-stone-300 dark:bg-stone-800 grow"></div>
                </div>
                <div class="prose prose-stone dark:prose-invert md:prose-xl font-serif mx-auto first-letter:text-6xl md:first-letter:text-7xl first-letter:font-bold first-letter:text-orange-500 first-letter:mr-3 first-letter:float-left">
                    <p class="leading-relaxed text-justify wrap-break-word">{sala.historia}</p>
                </div>
            </section>
    )}

    <section class="bg-stone-50 dark:bg-stone-900/20 py-24 border-t border-stone-200 dark:border-stone-800">
        <div class="max-w-7xl mx-auto px-8">
            <h2 class="text-4xl font-serif italic mb-12 text-center text-stone-900 dark:text-white font-bold">Imágenes de la Sala</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
                {galeriaSegura.map((img, i) => (
                        <div class="group relative aspect-[4/5] rounded-2xl overflow-hidden cursor-pointer shadow-md hover:shadow-2xl transition-all btn-visor hover:-translate-y-1" data-index={i}>
                            <img src={img} alt={`Imagen ${i + 1} de la colección`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <span class="bg-white/90 dark:bg-black/70 p-4 rounded-full text-xl shadow-xl">⛶</span>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <div id="visor" class="fixed inset-0 bg-white dark:bg-black z-[100] hidden opacity-0 transition-opacity duration-300 flex-col touch-none">

        <div class="p-6 flex justify-between items-center z-50">
            <div class="text-stone-500 dark:text-stone-400 font-bold tracking-widest text-[10px] uppercase">
                <span id="num" class="text-stone-900 dark:text-white text-base">1</span> / 8
            </div>
            <button id="cerrar" class="text-5xl leading-none text-stone-500 hover:text-orange-500 dark:text-stone-400 transition-colors cursor-pointer">&times;</button>
        </div>

        <div class="grow relative flex items-center justify-center p-4 md:p-16">
            {galeriaSegura.map((img, i) => (
                    <img src={img} alt={`Vista ampliada ${i + 1}`} class="slide absolute max-w-full max-h-full object-contain opacity-0 transition-opacity duration-300 shadow-2xl" data-index={i} />
            ))}
        </div>

        <button id="prev" class="absolute left-4 md:left-10 top-1/2 -translate-y-1/2 w-12 h-12 md:w-16 md:h-16 flex items-center justify-center rounded-full bg-stone-100/80 dark:bg-stone-900/80 backdrop-blur-md text-stone-900 dark:text-white text-3xl md:text-4xl shadow-lg hover:bg-orange-500 hover:text-white transition-all active:scale-90 z-50 cursor-pointer border border-stone-200 dark:border-stone-800">
            ‹
        </button>
        <button id="next" class="absolute right-4 md:right-10 top-1/2 -translate-y-1/2 w-12 h-12 md:w-16 md:h-16 flex items-center justify-center rounded-full bg-stone-100/80 dark:bg-stone-900/80 backdrop-blur-md text-stone-900 dark:text-white text-3xl md:text-4xl shadow-lg hover:bg-orange-500 hover:text-white transition-all active:scale-90 z-50 cursor-pointer border border-stone-200 dark:border-stone-800">
            ›
        </button>
    </div>

    <script>
        const visor = document.getElementById('visor');
        const slides = document.querySelectorAll('.slide');
        let current = 0;

        const show = (n: number) => {
            if (n < 0) n = slides.length - 1;
            if (n >= slides.length) n = 0;
            slides.forEach((s, i) => (s as HTMLElement).style.opacity = i === n ? '1' : '0');
            const numElement = document.getElementById('num');
            if (numElement) numElement.innerText = (n + 1).toString();
            current = n;
        };

        const abrirVisor = (index: number) => {
            if (visor) {
                visor.classList.remove('hidden');
                visor.classList.add('flex');
                document.body.style.overflow = 'hidden';
                document.body.style.touchAction = 'none';
                setTimeout(() => visor.classList.add('opacity-100'), 10);
                show(index);
            }
        };

        const cerrarVisor = () => {
            if (visor) {
                visor.classList.remove('opacity-100');
                document.body.style.overflow = '';
                document.body.style.touchAction = '';
                setTimeout(() => {
                    visor.classList.add('hidden');
                    visor.classList.remove('flex');
                }, 300);
            }
        };

        document.querySelectorAll('.btn-visor').forEach(b => {
            b.addEventListener('click', () => {
                const index = parseInt((b as HTMLElement).dataset.index || '0');
                abrirVisor(index);
            });
        });

        document.getElementById('cerrar')?.addEventListener('click', cerrarVisor);
        document.getElementById('next')?.addEventListener('click', () => show(current + 1));
        document.getElementById('prev')?.addEventListener('click', () => show(current - 1));

        document.addEventListener('keydown', (e) => {
            if (visor?.classList.contains('hidden')) return;
            if (e.key === 'Escape') cerrarVisor();
            if (e.key === 'ArrowRight') show(current + 1);
            if (e.key === 'ArrowLeft') show(current - 1);
        });
    </script>
</Layout>