---
import Layout from '../layouts/Layout.astro';
import prisma from '../lib/prisma';

// Traemos los datos de Render
const categorias = await prisma.categoria.findMany();
---

<Layout title="Inicio | Museo de Chocolate">

	<div class="mb-10 text-center">
		<h1 class="text-4xl md:text-5xl font-extrabold text-stone-800 mb-4">
			Descubre el Auténtico Sabor
		</h1>
		<p class="text-lg text-stone-600 max-w-2xl mx-auto">
			Explora nuestra cuidadosa selección de cacaos y chocolates finos, clasificados para verdaderos conocedores.
		</p>
	</div>

	<h2 class="text-2xl font-bold border-b-2 border-stone-200 pb-2 mb-6 text-stone-700">
		Nuestras Categorías
	</h2>

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
		{categorias.map(cat => (
			<div class="bg-white p-6 rounded-xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow">
				<h3 class="text-xl font-bold text-stone-800 mb-2">{cat.nombre}</h3>
				<p class="text-stone-600 text-sm">{cat.descripcion || "Sin descripción disponible."}</p>
			</div>
		))}
	</div>

	{categorias.length === 0 && (
		<div class="bg-orange-100 p-6 rounded-lg text-center text-orange-800">
			Aún no hay categorías registradas en la base de datos.
		</div>
	)}

</Layout>