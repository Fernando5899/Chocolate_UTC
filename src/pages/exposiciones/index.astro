---
import Layout from '../../layouts/Layout.astro';

const salas = [
    { id: '01', nombre: 'El Origen Botánico', desc: 'El hábitat sagrado del Theobroma Cacao.', img: 'https://images.unsplash.com/photo-1511381939415-e44015466834?q=80&w=2144' },
    { id: '02', nombre: 'Ritual Prehispánico', desc: 'Moneda y ofrenda de los dioses antiguos.', img: 'https://images.unsplash.com/photo-1620188467120-5042ed1eb5da?q=80&w=1974' },
    { id: '03', nombre: 'La Molienda Antigua', desc: 'Técnicas ancestrales de transformación.', img: 'https://images.unsplash.com/photo-1541093370339-78d9f109b0b4?q=80&w=2070' },
    { id: '04', nombre: 'El Viaje Transatlántico', desc: 'El impacto del cacao en la vieja Europa.', img: 'https://images.unsplash.com/photo-1606312619070-d48b4c652a52?q=80&w=1974' },
    { id: '05', nombre: 'La Revolución Industrial', desc: 'La invención de la primera barra sólida.', img: 'https://images.unsplash.com/photo-1589131668474-124b8969b83b?q=80&w=2070' },
];
---

<Layout title="Exposiciones | Recorrido Virtual">
    <div class="max-w-7xl mx-auto px-8 py-20 transition-colors duration-500">
        <header class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-10 transition-colors duration-500">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-sm font-bold block mb-4">Galería Principal</span>
            <h1 class="text-6xl font-black italic text-stone-900 dark:text-white mb-6 transition-colors duration-500">Exposiciones Permanentes</h1>
            <p class="text-xl text-stone-500 dark:text-stone-400 max-w-3xl transition-colors duration-500">Un recorrido cronológico por la historia del cacao. Desliza para explorar la colección curada del museo.</p>
        </header>

        <div class="relative group">
            <div class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar gap-8 pb-12">
                {salas.map((sala) => (
                        <div class="flex-none w-[85vw] md:w-[60vw] lg:w-[45vw] snap-center">
                            <div class="relative aspect-[16/10] overflow-hidden rounded-[40px] group/card shadow-2xl">
                                <img
                                        src={sala.img}
                                        class="w-full h-full object-cover grayscale opacity-90 group-hover/card:grayscale-0 group-hover/card:opacity-100 group-hover/card:scale-105 transition-all duration-1000"
                                        alt={sala.nombre}
                                />

                                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>

                                <div class="absolute bottom-10 left-10 right-10 z-10">
                                    <span class="text-orange-500 font-mono text-[10px] uppercase tracking-widest font-bold mb-3 block">SALA {sala.id}</span>
                                    <h3 class="text-4xl font-bold italic text-white mb-3 drop-shadow-lg">{sala.nombre}</h3>
                                    <p class="text-stone-300 text-sm md:text-base font-light max-w-sm drop-shadow-md">{sala.desc}</p>
                                </div>
                            </div>
                        </div>
                ))}
            </div>

            <div class="flex items-center gap-6 mt-4">
                <div class="h-px bg-stone-300 dark:bg-stone-800 flex-grow transition-colors duration-500"></div>
                <span class="text-[10px] uppercase tracking-widest text-stone-500 font-bold italic">Desliza para explorar →</span>
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Ocultar barra de desplazamiento pero mantener funcionalidad */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>