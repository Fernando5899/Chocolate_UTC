---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// Consultamos las salas reales de la base de datos
const salas = await prisma.sala.findMany({
    orderBy: { createdAt: 'desc' }
});
---

<Layout title="Exposiciones | Museo del Chocolate">
    <div class="max-w-7xl mx-auto px-8 py-20">

        <header class="mb-16">
            <h1 class="text-5xl md:text-6xl font-black italic text-stone-900 dark:text-white mb-4">Exposiciones Permanentes</h1>
            <p class="text-xl text-stone-600 dark:text-stone-400">Un recorrido cronológico por la historia del cacao. Desliza para explorar la colección curada del museo.</p>
        </header>

        {salas.length === 0 ? (
                <div class="text-center p-16 md:p-24 bg-stone-100 dark:bg-[#110e0d] rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-inner transition-colors duration-500">
                    <span class="text-6xl mb-6 block grayscale opacity-60">🚧</span>
                    <h2 class="text-3xl font-bold font-serif text-stone-900 dark:text-white mb-4 italic">Salas en Resguardo y Remodelación</h2>
                    <p class="text-stone-600 dark:text-stone-400 max-w-2xl mx-auto leading-relaxed">
                        Nuestros curadores y especialistas están preparando las nuevas exhibiciones de la temporada.
                        Las piezas históricas se encuentran actualmente en la bóveda de preservación para su mantenimiento.
                        <br><br>
                        <span class="font-bold text-orange-600 dark:text-orange-500">¡Vuelve pronto para descubrir la nueva cara del museo!</span>
                    </p>
                </div>
        ) : (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    {salas.map((sala) => (
                            <a href={`/salas/${sala.id}`} class="group relative h-[400px] overflow-hidden rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-all duration-500 hover:-translate-y-2">
                                <img src={sala.imagenUrl} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-90 dark:opacity-70" alt={sala.nombre} />

                                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent p-10 flex flex-col justify-end">
                                    <span class="text-orange-500 font-bold tracking-widest uppercase text-[10px] mb-3">Sala de Exhibición</span>
                                    <h2 class="text-4xl font-serif text-white italic drop-shadow-lg line-clamp-1">{sala.nombre}</h2>
                                    <p class="text-stone-200 mt-3 line-clamp-2 text-sm">{sala.descripcion}</p>
                                </div>
                            </a>
                    ))}
                </div>
        )}

    </div>
</Layout>