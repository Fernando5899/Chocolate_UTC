---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// Consultamos las salas reales de la base de datos
const salas = await prisma.sala.findMany({
    orderBy: { createdAt: 'desc' }
});
---

<Layout title="Exposiciones | Museo del Chocolate">
    <style>
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>

    <div class="max-w-[100vw] overflow-hidden py-24 md:py-32 flex flex-col">
        
        <div class="max-w-7xl mx-auto px-8 w-full">
            <header class="mb-16 max-w-3xl">
                <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.5em] text-[10px] md:text-xs font-black mb-4 block">
                    Colección Permanente
                </span>
                <h1 class="text-6xl md:text-8xl font-serif italic font-black text-stone-900 dark:text-white mb-8 leading-[0.9]">
                    Exposiciones
                </h1>
                <p class="text-lg md:text-xl text-stone-600 dark:text-stone-400 font-serif italic leading-relaxed">
                    Un recorrido cronológico por la historia del cacao. Desliza libremente para explorar la colección curada del museo.
                </p>
            </header>
        </div>

        {salas.length === 0 ? (
            <div class="max-w-7xl mx-auto px-8 w-full">
                <div class="text-center p-16 md:p-32 bg-stone-100 dark:bg-[#110e0d] rounded-[50px] border border-stone-200 dark:border-stone-800 transition-all duration-500">
                    <span class="text-7xl mb-8 block grayscale opacity-40">🏺</span>
                    <h2 class="text-3xl font-black font-serif text-stone-900 dark:text-white mb-4 italic">Salas en Remodelación</h2>
                    <p class="text-stone-500 dark:text-stone-400 max-w-md mx-auto font-serif italic">
                        Nuestros curadores están preparando las nuevas exhibiciones. Vuelve pronto para descubrir la nueva cara del museo.
                    </p>
                </div>
            </div>
        ) : (
            <div class="relative w-full">
                <div 
                    id="carrusel-salas" 
                    class="flex gap-6 md:gap-10 overflow-x-auto scrollbar-hide px-8 cursor-grab active:cursor-grabbing py-8"
                    style="scroll-behavior: auto; -webkit-overflow-scrolling: touch;"
                >
                    {salas.map((sala) => (
                        <a 
                            href={`/salas/${sala.id}`} 
                            class="item-sala group relative flex-none w-[80vw] md:w-[450px] aspect-square overflow-hidden rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-all duration-700 hover:-translate-y-3 select-none"
                            draggable="false"
                        >
                            <img 
                                src={sala.imagenUrl} 
                                class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-100 dark:opacity-60 grayscale group-hover:grayscale-0 pointer-events-none" 
                                alt={sala.nombre} 
                                draggable="false"
                            />

                            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent transition-opacity duration-500 group-hover:opacity-100"></div>

                            <div class="absolute inset-0 p-8 md:p-12 flex flex-col justify-end pointer-events-none">
                                <span class="text-orange-500 font-black tracking-[0.4em] uppercase text-[9px] mb-4 transform -translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                                    Sala de Exhibición
                                </span>
                                
                                <h2 class="text-3xl md:text-5xl font-serif text-white italic font-black leading-tight drop-shadow-2xl">
                                    {sala.nombre}
                                </h2>
                                
                                <p class="text-stone-300 mt-4 line-clamp-2 text-sm font-serif italic opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100">
                                    {sala.descripcion}
                                </p>

                                <div class="mt-6 flex items-center gap-4 opacity-0 group-hover:opacity-100 transition-all duration-1000 delay-200">
                                    <div class="h-px bg-orange-500 w-12"></div>
                                    <span class="text-white text-[10px] font-black uppercase tracking-widest">Explorar Sala</span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        )}

    </div>

    <script>
        const slider = document.getElementById('carrusel-salas');

        if (slider && slider.children.length > 0) {
            const items = Array.from(slider.children);
            
            // MULTIPLICADOR DE BUCLE: Clonamos varias veces para dar margen al scroll
            const numClones = 3;
            for(let i = 0; i < numClones; i++){
                items.forEach(item => slider.appendChild(item.cloneNode(true)));
            }

            let isDown = false;
            let startX = 0;
            let scrollLeft = 0;
            let isAutoScrolling = true;
            let frameId: number;

            // Función ultra-precisa para saber la medida de un bloque original (incluyendo los espacios/gaps)
            const getPuntoDeCorte = () => {
                const primerOriginal = slider.children[0] as HTMLElement;
                const primerClon = slider.children[items.length] as HTMLElement;
                return primerClon.offsetLeft - primerOriginal.offsetLeft;
            };

            // MOTOR DE FLUIDEZ A 60 FPS
            const autoScrollFluid = () => {
                if (isAutoScrolling && !isDown) {
                    slider.scrollLeft += 1; // Velocidad suave

                    const puntoDeCorte = getPuntoDeCorte();
                    
                    // Salto Mágico Invisible: Ocurre solo cuando el celular NO está tocando
                    if (slider.scrollLeft >= puntoDeCorte * 2) { 
                        slider.scrollLeft -= puntoDeCorte;
                    } else if (slider.scrollLeft <= 0) {
                        slider.scrollLeft += puntoDeCorte;
                    }
                }
                frameId = requestAnimationFrame(autoScrollFluid);
            };

            // Despegamos el motor gráfico
            frameId = requestAnimationFrame(autoScrollFluid);

            // Centramos el carrusel secretamente para que puedas dar swipe a la izquierda al instante
            setTimeout(() => {
                slider.scrollLeft = getPuntoDeCorte();
            }, 50);

            // --- PC MOUSE (DRAG & DROP) ---
            slider.addEventListener('mousedown', (e) => {
                isDown = true;
                isAutoScrolling = false;
                slider.classList.add('active:cursor-grabbing');
                startX = e.pageX - slider.offsetLeft;
                scrollLeft = slider.scrollLeft;
            });

            slider.addEventListener('mouseleave', () => {
                isDown = false;
                slider.classList.remove('active:cursor-grabbing');
                isAutoScrolling = true;
            });

            slider.addEventListener('mouseup', () => {
                isDown = false;
                slider.classList.remove('active:cursor-grabbing');
                isAutoScrolling = true;
            });

            slider.addEventListener('mousemove', (e) => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.pageX - slider.offsetLeft;
                const walk = (x - startX) * 2;
                slider.scrollLeft = scrollLeft - walk;
            });

            // --- CELULAR (TÁCTIL NATIVO Y SEGURO) ---
            let touchTimeout: ReturnType<typeof setTimeout>;

            slider.addEventListener('touchstart', () => {
                // Al tocar, apagamos nuestro motor JS y dejamos que Safari/Chrome tomen el control total
                isAutoScrolling = false;
                if (touchTimeout) clearTimeout(touchTimeout);
            }, { passive: true });

            slider.addEventListener('touchend', () => {
                // Esperamos 2 segundos completos después de soltar para que la "inercia" del celular termine
                // Antes de volver a prender nuestro motor
                touchTimeout = setTimeout(() => {
                    isAutoScrolling = true;
                }, 2000);
            }, { passive: true });
        }
    </script>
</Layout>