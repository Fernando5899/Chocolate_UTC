---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

const { id } = Astro.params;

const orden = await prisma.orden.findUnique({
    where: { id },
    include: {
        detalles: {
            include: {
                chocolate: true
            }
        }
    }
}) as any;

if (!orden) return Astro.redirect('/404');

// Separamos los boletos de los chocolates para el diseño
const detalles = orden.detalles || [];
---

<Layout title={`Boleto Digital #${orden.id.slice(-6).toUpperCase()} | UTC`}>
    <div class="min-h-screen bg-stone-200 dark:bg-[#0c0a09] py-12 px-6 flex justify-center items-center transition-colors duration-500">

        <div class="w-full max-w-md bg-white dark:bg-[#110e0d] shadow-[0_35px_60px_-15px_rgba(0,0,0,0.5)] rounded-3xl relative overflow-hidden transition-colors duration-500 border border-stone-300 dark:border-stone-800">

            <div class="bg-stone-900 dark:bg-stone-800 p-8 text-center relative">
                <div class="absolute top-0 left-0 w-full h-1 bg-orange-500"></div>
                <h1 class="text-white font-serif italic text-2xl tracking-tighter">Museo de Chocolate</h1>
                <p class="text-orange-500 uppercase tracking-[0.4em] text-[8px] font-black mt-2">Pase de Admisión Oficial</p>

                <div class="absolute -bottom-4 -left-4 w-8 h-8 bg-stone-200 dark:bg-[#0c0a09] rounded-full border border-stone-300 dark:border-stone-800"></div>
                <div class="absolute -bottom-4 -right-4 w-8 h-8 bg-stone-200 dark:bg-[#0c0a09] rounded-full border border-stone-300 dark:border-stone-800"></div>
            </div>

            <div class="p-8 pt-12 space-y-8">
                <div class="flex justify-between items-start border-b border-stone-100 dark:border-stone-800 pb-6">
                    <div>
                        <span class="text-[9px] uppercase font-bold text-stone-400 block mb-1">Titular del Pase</span>
                        <p class="text-xl font-serif font-bold text-stone-900 dark:text-white italic">{orden.clienteNombre}</p>
                    </div>
                    <div class="text-right">
                        <span class="text-[9px] uppercase font-bold text-stone-400 block mb-1">Fecha</span>
                        <p class="text-xs font-mono text-stone-600 dark:text-stone-300">{new Date(orden.fecha).toLocaleDateString('es-MX')}</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <span class="text-[9px] font-bold uppercase tracking-widest text-orange-600">Manifiesto de Compra</span>

                    <div class="space-y-3">
                        {detalles.map((item: any) => (
                                <div class="flex justify-between items-center text-sm">
                                    <div class="flex flex-col">
                                    <span class="font-bold text-stone-900 dark:text-white italic">
                                        {item.chocolate ? item.chocolate.nombre : "🎟️ Boleto de Acceso"}
                                    </span>
                                        <span class="text-[10px] text-stone-500 uppercase tracking-tighter">Cantidad: {item.cantidad}</span>
                                    </div>
                                    <span class="font-mono text-stone-600 dark:text-stone-400 text-xs">
                                    ${(item.precioUnit * item.cantidad).toFixed(2)}
                                </span>
                                </div>
                        ))}
                    </div>
                </div>

                <div class="bg-stone-50 dark:bg-[#0c0a09] p-6 rounded-2xl border-2 border-dashed border-stone-200 dark:border-stone-800 flex justify-between items-center mt-6">
                    <div class="flex flex-col">
                        <span class="text-[9px] font-black text-stone-400 uppercase tracking-widest">Total Pagado</span>
                        <span class="text-3xl font-black text-stone-900 dark:text-white">${Number(orden.total).toFixed(2)}</span>
                    </div>
                    <div class="h-12 w-px bg-stone-200 dark:border-stone-800"></div>
                    <div class="text-right">
                        <span class="text-[9px] font-black text-stone-400 uppercase tracking-widest block">Folio</span>
                        <span class="text-xs font-mono font-bold text-stone-900 dark:text-white">#{orden.id.slice(-8).toUpperCase()}</span>
                    </div>
                </div>
            </div>

            <div class="p-8 bg-stone-50 dark:bg-stone-900/20 text-center border-t border-stone-100 dark:border-stone-800 relative">
                <div class="absolute -top-4 -left-4 w-8 h-8 bg-stone-200 dark:bg-[#0c0a09] rounded-full border border-stone-300 dark:border-stone-800"></div>
                <div class="absolute -top-4 -right-4 w-8 h-8 bg-stone-200 dark:bg-[#0c0a09] rounded-full border border-stone-300 dark:border-stone-800"></div>

                <p class="text-[9px] text-stone-400 font-bold uppercase tracking-[0.3em] mb-6">Escaneo de Seguridad UTC</p>

                <div class="flex justify-center mb-6">
                    <img src={`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${orden.id}&color=1c1917`}
                         class="w-32 h-32 border-4 border-white shadow-xl rounded-xl"
                         alt="QR de Verificación" />
                </div>

                <button onclick="window.print()" class="no-print w-full bg-stone-900 dark:bg-white text-white dark:text-black py-4 rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-orange-600 transition-all cursor-pointer">
                    Descargar Ticket PDF 📄
                </button>
            </div>
        </div>
    </div>
</Layout>

<style>
    @media print {
        .no-print { display: none; }
        body { background: white !important; }
        .shadow-2xl { box-shadow: none !important; }
    }
</style>