---
// Ya no importamos Layout.astro, porque queremos una página totalmente limpia
import prisma from '../../lib/prisma';
import '../../styles/global.css'; // Importamos Tailwind directamente

const { id } = Astro.params;

const orden = await prisma.orden.findUnique({
    where: { id },
    include: {
        detalles: {
            include: {
                chocolate: true
            }
        }
    }
}) as any;

if (!orden) return Astro.redirect('/404');

const detalles = orden.detalles || [];
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Pase de Acceso | Museo de Chocolate</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body class="bg-stone-200 dark:bg-[#0c0a09] min-h-screen flex justify-center items-center py-8 px-4 font-sans selection:bg-orange-500 selection:text-white transition-colors duration-500">

<div class="w-full max-w-md bg-white dark:bg-[#110e0d] shadow-2xl rounded-[40px] relative overflow-hidden border border-stone-300 dark:border-stone-800">

    <div class="bg-stone-900 dark:bg-black p-10 text-center relative border-b border-orange-600/30">
        <h1 class="text-white font-serif italic font-black text-3xl tracking-tight">Museo de Chocolate</h1>
        <p class="text-orange-500 uppercase tracking-[0.4em] text-[9px] font-black mt-3">Pase de Admisión Oficial</p>

        <div class="absolute -bottom-5 -left-5 w-10 h-10 bg-stone-200 dark:bg-[#0c0a09] rounded-full border-t border-r border-stone-300 dark:border-stone-800 transition-colors duration-500"></div>
        <div class="absolute -bottom-5 -right-5 w-10 h-10 bg-stone-200 dark:bg-[#0c0a09] rounded-full border-t border-l border-stone-300 dark:border-stone-800 transition-colors duration-500"></div>
    </div>

    <div class="p-10 pt-12 space-y-8">
        
        <div class="flex justify-between items-end border-b border-stone-200 dark:border-stone-800 pb-6">
            <div>
                <span class="text-[9px] uppercase font-black text-stone-400 block tracking-[0.2em] mb-1">Titular del Pase</span>
                <p class="text-xl font-serif font-black text-stone-900 dark:text-white italic leading-none truncate max-w-[200px]">{orden.clienteNombre}</p>
            </div>
            <div class="text-right">
                <span class="text-[9px] uppercase font-black text-stone-400 block tracking-[0.2em] mb-1">Fecha</span>
                <span class="font-mono text-xs font-bold text-stone-600 dark:text-stone-300">{new Date(orden.fecha).toLocaleDateString('es-MX')}</span>
            </div>
        </div>

        <div class="space-y-4">
            <span class="text-[9px] font-black uppercase tracking-[0.3em] text-orange-600 block mb-2">Manifiesto de Compra</span>
            {detalles.map((item: any) => (
                <div class="flex justify-between text-sm items-center">
                    <span class="dark:text-stone-300 text-stone-600 font-serif italic">
                        <span class="font-sans font-bold text-stone-400 text-xs mr-2">{item.cantidad}x</span> 
                        {item.chocolate ? item.chocolate.nombre : (item.nombreItem || "Pase de Admisión")}
                    </span>
                    <span class="font-bold font-mono text-stone-900 dark:text-white">${(item.precioUnit * item.cantidad).toFixed(2)}</span>
                </div>
            ))}
        </div>

        <div class="bg-stone-50 dark:bg-[#0c0a09] p-6 rounded-3xl border border-stone-200 dark:border-stone-800 flex justify-between items-center">
            <div>
                <span class="text-[9px] font-black text-stone-400 uppercase tracking-[0.3em] block mb-1">Aporte Total</span>
                <span class="text-3xl font-black text-stone-900 dark:text-white font-mono tracking-tighter">${orden.total.toFixed(2)}</span>
            </div>
            <div class="text-right">
                <span class="text-[9px] font-black text-stone-400 uppercase tracking-[0.3em] block mb-1">Folio</span>
                <span class="text-sm font-mono font-bold text-stone-600 dark:text-stone-400">#{orden.id.slice(-8).toUpperCase()}</span>
            </div>
        </div>

        <div class="text-center pt-6">
            <span class="text-[9px] font-black uppercase tracking-[0.4em] text-stone-400 block mb-6">Escaneo de Seguridad UTC</span>
            <div class="flex justify-center">
                <div class="bg-white p-3 rounded-2xl shadow-sm border border-stone-200 dark:border-stone-800 inline-block">
                    <img src={`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${orden.id}&color=1c1917`} class="w-32 h-32 rounded-lg" alt="Código QR Institucional" />
                </div>
            </div>
        </div>

        <div class="no-print pt-4">
            <button onclick="window.print()" class="w-full bg-stone-900 dark:bg-white text-white dark:text-black py-5 rounded-full text-[10px] font-black uppercase tracking-[0.3em] hover:bg-orange-600 dark:hover:bg-orange-600 dark:hover:text-white transition-all cursor-pointer shadow-xl active:scale-95 mb-4">
                Descargar Ticket PDF
            </button>
            <div class="text-center">
                <a href="/tienda/chocolates" class="text-[10px] font-bold uppercase tracking-[0.2em] text-stone-400 hover:text-orange-500 transition-colors border-b border-transparent hover:border-orange-500 pb-1">
                    Volver a la tienda
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    @media print {
        .no-print { display: none !important; }
        body { 
            background: white !important; 
            display: block;
            padding: 0;
            margin: 0;
        }
        .shadow-2xl, .shadow-sm, .shadow-xl { box-shadow: none !important; }
        /* Expandimos el ticket y quitamos bordes para la impresión en A4 o Ticketera */
        .max-w-md {
            max-width: 100% !important;
            border: none !important;
            border-radius: 0 !important;
        }
        /* Ocultamos las perforaciones simuladas al imprimir */
        .rounded-full.border-t { display: none !important; }
    }
</style>

<script>
    // Recuperamos el tema para que la vista aislada respete si el usuario usa Dark Mode
    const theme = localStorage.getItem('theme') || 'dark';
    if (theme === 'dark') {
        document.documentElement.classList.add('dark');
    }
</script>

</body>
</html>