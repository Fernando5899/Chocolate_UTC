---
// Ya no importamos Layout.astro, porque queremos una página totalmente limpia
import prisma from '../../lib/prisma';
import '../../styles/global.css'; // Importamos Tailwind directamente

const { id } = Astro.params;

const orden = await prisma.orden.findUnique({
    where: { id },
    include: {
        detalles: {
            include: {
                chocolate: true
            }
        }
    }
}) as any;

if (!orden) return Astro.redirect('/404');

const detalles = orden.detalles || [];
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Pase de Acceso | UTC</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body class="bg-stone-200 dark:bg-[#0c0a09] min-h-screen flex justify-center items-center py-8 px-4 font-sans selection:bg-orange-500 selection:text-white">

<div class="w-full max-w-md bg-white dark:bg-[#110e0d] shadow-2xl rounded-3xl relative overflow-hidden border border-stone-300 dark:border-stone-800">

    <div class="bg-stone-900 dark:bg-stone-800 p-8 text-center relative border-b-4 border-orange-600">
        <h1 class="text-white font-serif italic text-2xl">Museo de Chocolate</h1>
        <p class="text-orange-500 uppercase tracking-[0.4em] text-[8px] font-black mt-2">Pase de Admisión Oficial</p>

        <div class="absolute -bottom-4 -left-4 w-8 h-8 bg-stone-200 dark:bg-[#0c0a09] rounded-full"></div>
        <div class="absolute -bottom-4 -right-4 w-8 h-8 bg-stone-200 dark:bg-[#0c0a09] rounded-full"></div>
    </div>

    <div class="p-8 pt-10 space-y-6">
        <div class="flex justify-between items-end border-b border-stone-100 dark:border-stone-800 pb-4">
            <div>
                <span class="text-[8px] uppercase font-black text-stone-400 block tracking-widest">Titular del Pase</span>
                <p class="text-lg font-serif font-bold text-stone-900 dark:text-white italic">{orden.clienteNombre}</p>
            </div>
            <div class="text-right">
                <span class="text-[8px] uppercase font-black text-stone-400 block tracking-widest">Fecha</span>
                <span class="font-mono text-[10px] text-stone-500">{new Date(orden.fecha).toLocaleDateString('es-MX')}</span>
            </div>
        </div>

        <div class="space-y-3">
            <span class="text-[8px] font-black uppercase tracking-widest text-orange-600">Manifiesto de Compra</span>
            {detalles.map((item: any) => (
                    <div class="flex justify-between text-sm italic">
                        <span class="dark:text-stone-300 text-stone-600">
                            {/* AQUÍ ESTÁ LA MAGIA: Si hay chocolate pone el nombre, si no, pone el nombreItem del boleto */}
                            {item.cantidad}x {item.chocolate ? item.chocolate.nombre : (item.nombreItem || "🎟️ Pase de Admisión")}
                        </span>
                        <span class="font-bold text-stone-900 dark:text-white">${(item.precioUnit * item.cantidad).toFixed(2)}</span>
                    </div>
            ))}
        </div>

        <div class="bg-stone-50 dark:bg-stone-900/50 p-6 rounded-2xl border-2 border-dashed border-stone-200 dark:border-stone-800 flex justify-between items-center">
            <div>
                <span class="text-[8px] font-black text-stone-400 uppercase tracking-widest block">Total Pagado</span>
                <span class="text-3xl font-black text-stone-900 dark:text-white">${orden.total.toFixed(2)}</span>
            </div>
            <div class="text-right">
                <span class="text-[8px] font-black text-stone-400 uppercase tracking-widest block">Folio</span>
                <span class="text-xs font-mono font-bold text-stone-900 dark:text-white">#{orden.id.slice(-8).toUpperCase()}</span>
            </div>
        </div>

        <div class="text-center pt-4">
            <span class="text-[8px] font-black uppercase tracking-widest text-stone-400 block mb-4">Escaneo de Seguridad UTC</span>
            <div class="flex justify-center">
                <img src={`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${orden.id}&color=1c1917`} class="w-32 h-32 border-4 border-white shadow-lg rounded-xl" alt="Código QR Institucional" />
            </div>
        </div>

        <button onclick="window.print()" class="no-print w-full mt-6 bg-stone-900 dark:bg-white text-white dark:text-black py-4 rounded-xl text-[9px] font-black uppercase tracking-widest hover:bg-orange-600 transition-all cursor-pointer shadow-xl active:scale-95">
            Descargar Ticket PDF 📄
        </button>
    </div>
</div>

<style>
    /* Ocultamos el botón al momento de imprimir o guardar como PDF */
    @media print {
        .no-print { display: none; }
        body { background: white !important; }
        .shadow-2xl { box-shadow: none !important; }
    }
</style>

</body>
</html>