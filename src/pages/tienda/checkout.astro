---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

// 1. EL CADENERO (Gatekeeper)
const session = await getSession(Astro.request);

// Si no hay sesión activa, mandamos al Login
if (!session) {
    return Astro.redirect('/cuenta/login');
}

// 2. Buscamos sus datos en la base de datos
const usuario = await prisma.user.findUnique({
    where: { email: session.user?.email || '' }
});
---

<Layout title="Finalizar Pedido | Museo">
    <div class="max-w-7xl mx-auto px-8 py-24 md:py-32 transition-colors duration-500">
        
        <header class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-10">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-[10px] font-black block mb-4">Proceso de Pago</span>
            <h1 class="text-5xl md:text-7xl font-serif italic font-black text-stone-900 dark:text-white transition-colors duration-500 tracking-tight">Finalizar Pedido</h1>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

            <div class="lg:col-span-7 xl:col-span-8 space-y-8">
                
                <section id="seccion-entrega" class="bg-white dark:bg-[#110e0d] p-10 md:p-14 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-colors duration-500">
                    <h2 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-10 border-b border-stone-100 dark:border-stone-800/80 pb-6 flex items-center gap-4">
                        <span class="text-orange-500 text-2xl">📍</span> Datos de Entrega Autorizados
                    </h2>

                    <form id="form-checkout" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <input type="hidden" id="user-id" value={usuario?.id} />

                        <div>
                            <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-3 font-black">Nombre del Titular</label>
                            <input type="text" id="input-nombre" value={usuario?.name} class="input-requerido-fisico w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl outline-none focus:ring-1 focus:ring-orange-500 focus:border-orange-500 text-sm font-bold text-stone-900 dark:text-white transition-all" />
                        </div>

                        <div>
                            <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-3 font-black">Correo de Recibo (Verificado)</label>
                            <input type="email" id="input-email" value={session.user?.email} readonly class="w-full bg-stone-100 dark:bg-[#0a0807] border border-stone-200 dark:border-stone-800/50 p-5 rounded-2xl outline-none text-sm font-bold text-stone-500 dark:text-stone-600 cursor-not-allowed transition-all" />
                        </div>

                        <div>
                            <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-3 font-black">Entidad</label>
                            <select id="selector-estado" class="input-requerido-fisico w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl outline-none focus:ring-1 focus:ring-orange-500 focus:border-orange-500 text-sm font-bold text-stone-900 dark:text-white appearance-none transition-all cursor-pointer">
                                <option value="" disabled selected>Selecciona una opción...</option>
                                <option value="CDMX" selected={usuario?.estado === 'CDMX'}>Ciudad de México</option>
                                <option value="Edomex" selected={usuario?.estado === 'Edomex'}>Estado de México</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-3 font-black">Código Postal</label>
                            <input type="text" id="input-cp" value={usuario?.codigoPostal} maxlength="5" class="input-requerido-fisico w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl outline-none focus:ring-1 focus:ring-orange-500 focus:border-orange-500 text-sm font-bold text-stone-900 dark:text-white font-mono transition-all" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-3 font-black">Dirección Completa</label>
                            <input type="text" id="input-direccion" value={usuario?.direccion} placeholder="Calle, Número, Colonia..." class="input-requerido-fisico w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl outline-none focus:ring-1 focus:ring-orange-500 focus:border-orange-500 text-sm font-bold text-stone-900 dark:text-white transition-all" />
                        </div>
                    </form>
                </section>

                <section id="seccion-pase-rapido" class="hidden bg-orange-50 dark:bg-orange-900/10 p-10 md:p-14 rounded-[40px] border border-orange-200 dark:border-orange-900/30 text-center shadow-lg transition-all duration-500">
                    <span class="text-5xl mb-6 block drop-shadow-sm">🎟️</span>
                    <h2 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-4">Compra Digital Exprés</h2>
                    <p class="text-stone-600 dark:text-stone-400 text-base font-serif italic max-w-lg mx-auto leading-relaxed">
                        Al llevar únicamente boletos de acceso, no necesitamos tu dirección de entrega física. El ticket llegará directamente a tu correo verificado de forma inmediata.
                    </p>
                </section>

            </div>

            <div class="lg:col-span-5 xl:col-span-4">
                <div class="bg-stone-50 dark:bg-[#0c0a09] p-10 rounded-[40px] shadow-2xl border border-stone-200 dark:border-stone-800 sticky top-32 transition-colors duration-500">
                    <h2 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-8 border-b border-stone-200 dark:border-stone-800 pb-6">Resumen</h2>

                    <div class="space-y-5 mb-10" id="lista-resumen">
                    </div>

                    <div class="space-y-5 border-t border-stone-200 dark:border-stone-800 pt-8 mb-10 transition-colors duration-500">
                        <div class="flex justify-between text-stone-500 uppercase tracking-widest text-[10px] font-bold">
                            <span>Subtotal</span>
                            <span id="subtotal-final" class="text-stone-900 dark:text-white text-sm font-black font-mono">$0.00</span>
                        </div>
                        <div class="flex justify-between text-orange-600 dark:text-orange-500 uppercase tracking-widest text-[10px] font-bold">
                            <span id="label-envio">Logística Metro</span>
                            <span id="envio-costo" class="text-sm font-black font-mono">$0.00</span>
                        </div>
                        <div class="flex flex-col pt-8 border-t border-stone-200 dark:border-stone-800 mt-6 transition-colors duration-500 gap-2">
                            <span class="text-[10px] uppercase tracking-[0.3em] text-stone-400 font-black block w-full">Aporte Total</span>
                            <span id="total-final" class="text-5xl font-serif italic font-black text-stone-900 dark:text-white drop-shadow-sm w-full text-right block tracking-tighter">$0.00</span>
                        </div>
                    </div>

                    <button id="btn-pagar" class="w-full bg-stone-900 dark:bg-white text-white dark:text-black hover:bg-orange-600 hover:dark:bg-orange-600 hover:text-white transition-all shadow-xl font-black py-5 rounded-full transform active:scale-95 cursor-pointer uppercase text-[10px] tracking-[0.3em]">
                        Confirmar Orden Segura
                    </button>

                    <div class="text-center mt-8 pt-8 border-t border-stone-200 dark:border-stone-800">
                        <span class="text-[9px] font-black uppercase tracking-[0.4em] text-stone-400 block mb-2 flex items-center justify-center gap-2">
                            <span>🔒</span> Transacción Encriptada
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        import { carrito } from '../../store/carrito';

        const selectorEstado = document.getElementById('selector-estado') as HTMLSelectElement;
        const envioCostoTxt = document.getElementById('envio-costo');
        const labelEnvio = document.getElementById('label-envio');
        const subtotalTxt = document.getElementById('subtotal-final');
        const totalTxt = document.getElementById('total-final');
        const listaResumen = document.getElementById('lista-resumen');
        
        const seccionEntrega = document.getElementById('seccion-entrega');
        const seccionPaseRapido = document.getElementById('seccion-pase-rapido');
        const inputsFisicos = document.querySelectorAll('.input-requerido-fisico');

        const COSTOS_ENVIO: Record<string, number> = {
            'CDMX': 0,
            'Edomex': 99
        };

        let modoSoloDigital = false;

        function actualizarResumen() {
            const items = Object.values(carrito.get());
            let subtotal = 0;

            const tieneProductosFisicos = items.some(item => 
                !item.id.includes('ticket') && !item.id.includes('boleto')
            );
            
            modoSoloDigital = !tieneProductosFisicos;

            if (modoSoloDigital) {
                seccionEntrega?.classList.add('hidden');
                seccionPaseRapido?.classList.remove('hidden');
                inputsFisicos.forEach((input: any) => input.removeAttribute('required'));
            } else {
                seccionEntrega?.classList.remove('hidden');
                seccionPaseRapido?.classList.add('hidden');
                inputsFisicos.forEach((input: any) => input.setAttribute('required', 'true'));
            }

            if (listaResumen) listaResumen.innerHTML = '';

            items.forEach(item => {
                subtotal += item.precio * item.cantidad;
                // ACTUALIZACIÓN DE ESTILO EN EL DOM GENERADO POR JS
                listaResumen?.insertAdjacentHTML('beforeend', `
                    <div class="flex justify-between items-center group">
                        <span class="font-serif italic text-stone-600 dark:text-stone-300 text-sm">
                            <span class="font-sans font-bold text-stone-400 text-xs mr-2">${item.cantidad}x</span> 
                            ${item.nombre}
                        </span>
                        <span class="font-mono font-bold text-stone-900 dark:text-white group-hover:text-orange-500 transition-colors">$${(item.precio * item.cantidad).toFixed(2)}</span>
                    </div>
                `);
            });

            const zona = selectorEstado?.value || 'CDMX';
            let costoEnvio = 0;

            if (!modoSoloDigital) {
                costoEnvio = COSTOS_ENVIO[zona] || 0;
                if (labelEnvio) labelEnvio.innerText = "Logística Metro";
            } else {
                costoEnvio = 0;
                if (labelEnvio) labelEnvio.innerText = "Entrega Digital";
            }

            const total = subtotal + costoEnvio;

            if (subtotalTxt) subtotalTxt.innerText = `$${subtotal.toFixed(2)}`;
            if (envioCostoTxt) envioCostoTxt.innerText = costoEnvio === 0 ? 'GRATIS' : `$${costoEnvio.toFixed(2)}`;
            if (totalTxt) totalTxt.innerText = `$${total.toFixed(2)}`;
        }

        selectorEstado?.addEventListener('change', actualizarResumen);
        actualizarResumen();

        document.getElementById('btn-pagar')?.addEventListener('click', async () => {
            const btn = document.getElementById('btn-pagar') as HTMLButtonElement;

            const inputNombre = document.getElementById('input-nombre') as HTMLInputElement;
            const inputEmail = document.getElementById('input-email') as HTMLInputElement;
            const inputCp = document.getElementById('input-cp') as HTMLInputElement;
            const inputDireccion = document.getElementById('input-direccion') as HTMLInputElement;
            const inputUserId = document.getElementById('user-id') as HTMLInputElement;

            const userId = inputUserId?.value;
            const email = inputEmail?.value;
            
            let nombreEnvio = "";
            let cpEnvio = "";
            let direccionEnvio = "";
            let estadoEnvio = "Digital";

            if (!modoSoloDigital) {
                nombreEnvio = inputNombre?.value;
                cpEnvio = inputCp?.value;
                direccionEnvio = inputDireccion?.value;
                estadoEnvio = selectorEstado?.value;

                if (!nombreEnvio || !direccionEnvio || !cpEnvio || !estadoEnvio) {
                    alert("⚠️ Por favor, completa tu información de entrega.");
                    return;
                }
            } else {
                nombreEnvio = inputNombre?.value || "Cliente Digital"; // Toma el nombre si existe
                cpEnvio = "00000";
                direccionEnvio = "Envío por Correo Electrónico";
            }

            btn.disabled = true;
            btn.innerText = "PROCESANDO...";

            const ordenData = {
                clienteNombre: nombreEnvio,
                email: email,
                estadoEnvio: estadoEnvio,
                direccion: direccionEnvio,
                codigoPostal: cpEnvio,
                total: parseFloat(totalTxt?.innerText.replace('$', '') || '0'),
                items: Object.values(carrito.get()),
                userId: userId
            };

            try {
                const response = await fetch('/api/ordenes', {
                    method: 'POST',
                    body: JSON.stringify(ordenData),
                    headers: { 'Content-Type': 'application/json' }
                });

                const result = await response.json();

                if (response.ok) {
                    carrito.set({}); 
                    window.location.href = `/tienda/gracias?orden=${result.orden.id}`;
                } else {
                    throw new Error(result.error || "El servidor rechazó la orden.");
                }
            } catch (error) {
                const mensajeError = error instanceof Error ? error.message : "Error desconocido de red.";
                alert(`❌ Ocurrió un problema: ${mensajeError}`);
                btn.disabled = false;
                btn.innerText = "CONFIRMAR ORDEN SEGURA";
            }
        });
    </script>
</Layout>