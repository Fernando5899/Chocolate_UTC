---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Finalizar Compra | Museo">
    <div class="max-w-5xl mx-auto">
        <h1 class="text-3xl font-bold text-stone-800 mb-8">Finalizar Pedido</h1>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
            <div class="lg:col-span-2 space-y-6">
                <section class="bg-white p-8 rounded-2xl shadow-sm border border-stone-200">
                    <h2 class="text-xl font-bold text-stone-800 mb-6 flex items-center gap-2">
                        <span>📍</span> Datos de Entrega
                    </h2>

                    <form id="form-checkout" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-stone-600 mb-1">Nombre Completo</label>
                            <input type="text" required class="w-full px-4 py-2 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500" />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-stone-600 mb-1">Estado</label>
                            <select id="selector-estado" required class="w-full px-4 py-2 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500 bg-white">
                                <option value="" disabled selected>Selecciona tu estado...</option>
                                <option value="CDMX">Ciudad de México</option>
                                <option value="Edomex">Estado de México</option>
                                <option value="Norte">Nuevo León / Jalisco / Norte</option>
                                <option value="Resto">Resto de la República</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-stone-600 mb-1">Código Postal</label>
                            <input type="text" maxlength="5" required class="w-full px-4 py-2 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-stone-600 mb-1">Dirección (Calle y Número)</label>
                            <input type="text" required class="w-full px-4 py-2 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500" />
                        </div>
                    </form>
                </section>

                <section class="bg-white p-8 rounded-2xl shadow-sm border border-stone-200">
                    <h2 class="text-xl font-bold text-stone-800 mb-6 flex items-center gap-2">
                        <span>💳</span> Método de Pago
                    </h2>
                    <div class="space-y-4">
                        <div class="border-2 border-orange-500 p-4 rounded-xl bg-orange-50 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl">💳</span>
                                <div>
                                    <p class="font-bold text-stone-800">Tarjeta de Crédito/Débito</p>
                                    <p class="text-xs text-stone-500">Procesamiento seguro cifrado</p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <div class="w-8 h-5 bg-stone-300 rounded"></div>
                                <div class="w-8 h-5 bg-stone-300 rounded"></div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-stone-900 text-white p-8 rounded-2xl shadow-xl sticky top-28">
                    <h2 class="text-xl font-bold mb-6 border-b border-stone-700 pb-4">Resumen de Orden</h2>

                    <div class="space-y-3 text-stone-400 text-sm mb-6" id="lista-resumen">
                    </div>

                    <div class="space-y-3 border-t border-stone-700 pt-6 mb-8">
                        <div class="flex justify-between">
                            <span>Subtotal</span>
                            <span id="subtotal-final">$0.00</span>
                        </div>
                        <div class="flex justify-between text-orange-400 font-bold">
                            <span>Envío Nacional</span>
                            <span id="envio-costo">$0.00</span>
                        </div>
                        <div class="flex justify-between text-xl font-black text-white pt-4">
                            <span>Total</span>
                            <span id="total-final">$0.00</span>
                        </div>
                    </div>

                    <button id="btn-pagar" class="w-full bg-orange-600 hover:bg-orange-500 text-white font-black py-4 rounded-xl transition-all shadow-lg transform active:scale-95 cursor-pointer">
                        PAGAR AHORA
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { carrito } from '../../store/carrito';

        const selectorEstado = document.getElementById('selector-estado') as HTMLSelectElement;
        const envioCostoTxt = document.getElementById('envio-costo');
        const subtotalTxt = document.getElementById('subtotal-final');
        const totalTxt = document.getElementById('total-final');
        const listaResumen = document.getElementById('lista-resumen');

        // Configuración de costos por zona
        const COSTOS_ENVIO: Record<string, number> = {
            'CDMX': 0,      // Gratis en CDMX
            'Edomex': 99,   // Tarifa Edomex
            'Norte': 180,   // Tarifa Norte
            'Resto': 150    // Resto del país
        };

        function actualizarResumen() {
            const items = Object.values(carrito.get());
            let subtotal = 0;

            if (listaResumen) listaResumen.innerHTML = '';

            items.forEach(item => {
                subtotal += item.precio * item.cantidad;
                listaResumen?.insertAdjacentHTML('beforeend', `
                    <div class="flex justify-between italic">
                        <span>${item.cantidad}x ${item.nombre}</span>
                        <span>$${(item.precio * item.cantidad).toFixed(2)}</span>
                    </div>
                `);
            });

            const zona = selectorEstado.value || 'CDMX';
            const costoEnvio = COSTOS_ENVIO[zona] || 0;
            const total = subtotal + costoEnvio;

            if (subtotalTxt) subtotalTxt.innerText = `$${subtotal.toFixed(2)}`;
            if (envioCostoTxt) envioCostoTxt.innerText = `$${costoEnvio.toFixed(2)}`;
            if (totalTxt) totalTxt.innerText = `$${total.toFixed(2)}`;
        }

        // Escuchar cuando el usuario cambie de estado
        selectorEstado?.addEventListener('change', actualizarResumen);

        // Inicializar
        actualizarResumen();

        // Simulación de pago
        document.getElementById('btn-pagar')?.addEventListener('click', () => {
            const btn = document.getElementById('btn-pagar') as HTMLButtonElement;
            btn.disabled = true;
            btn.innerText = "Procesando pago seguro...";

            setTimeout(() => {
                alert("¡Gracias por tu compra! Tu pedido nacional está en camino. 🍫📦");
                carrito.set({}); // Vaciamos el carrito
                window.location.href = "/";
            }, 3000);
        });
    </script>
</Layout>