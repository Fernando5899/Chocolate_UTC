---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

// 1. Obtener sesión y datos del perfil para autocompletar
const session = await getSession(Astro.request);
let usuario = null;

if (session) {
    usuario = await prisma.user.findUnique({
        where: { email: session.user?.email || '' }
    });
}
---

<Layout title="Finalizar Pedido | Museo">
    <div class="max-w-5xl mx-auto py-12">
        <header class="mb-12">
            <span class="text-orange-500 uppercase tracking-[0.4em] text-[10px] font-bold block mb-4">Proceso de Pago</span>
            <h1 class="text-5xl font-black italic">Finalizar Pedido</h1>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2 space-y-8">

                {!session && (
                        <div class="bg-orange-950/20 border border-orange-900/50 p-6 rounded-2xl flex items-center justify-between">
                            <p class="text-sm text-orange-200/70 italic">¿Tienes una cuenta? Inicia sesión para usar tus datos guardados.</p>
                            <a href="/cuenta/login" class="text-[10px] font-bold uppercase tracking-widest text-white border-b border-white hover:text-orange-400 hover:border-orange-400 transition-all">Ingresar</a>
                        </div>
                )}

                <section class="bg-stone-900/40 p-10 rounded-3xl border border-stone-800 shadow-2xl">
                    <h2 class="text-xl font-bold italic mb-8 flex items-center gap-3">
                        <span class="text-orange-500">📍</span> Detalles de Entrega
                    </h2>

                    <form id="form-checkout" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <input type="hidden" id="user-id" value={usuario?.id} />

                        <div class="md:col-span-2">
                            <label class="block text-[10px] uppercase tracking-[0.2em] text-stone-500 mb-2 font-bold">Nombre Completo</label>
                            <input type="text" id="input-nombre" value={usuario?.name} required class="w-full bg-black/40 border border-stone-800 p-3 rounded-xl focus:border-orange-500 outline-none transition-all text-stone-200" />
                        </div>

                        <div>
                            <label class="block text-[10px] uppercase tracking-[0.2em] text-stone-500 mb-2 font-bold">Entidad</label>
                            <select id="selector-estado" required class="w-full bg-black/40 border border-stone-800 p-3 rounded-xl focus:border-orange-500 outline-none transition-all text-stone-200 appearance-none">
                                <option value="" disabled selected>Selecciona...</option>
                                <option value="CDMX" selected={usuario?.estado === 'CDMX'}>Ciudad de México</option>
                                <option value="Edomex" selected={usuario?.estado === 'Edomex'}>Estado de México</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-[10px] uppercase tracking-[0.2em] text-stone-500 mb-2 font-bold">Código Postal</label>
                            <input type="text" id="input-cp" value={usuario?.codigoPostal} maxlength="5" required class="w-full bg-black/40 border border-stone-800 p-3 rounded-xl focus:border-orange-500 outline-none transition-all text-stone-200" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-[10px] uppercase tracking-[0.2em] text-stone-500 mb-2 font-bold">Dirección Completa</label>
                            <input type="text" id="input-direccion" value={usuario?.direccion} required class="w-full bg-black/40 border border-stone-800 p-3 rounded-xl focus:border-orange-500 outline-none transition-all text-stone-200" />
                        </div>
                    </form>
                </section>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-black p-10 rounded-3xl border border-stone-800 shadow-2xl sticky top-28">
                    <h2 class="text-xl font-bold italic mb-8 border-b border-stone-900 pb-6">Resumen</h2>

                    <div class="space-y-4 text-stone-400 text-sm mb-8 italic" id="lista-resumen">
                    </div>

                    <div class="space-y-4 border-t border-stone-900 pt-8 mb-10">
                        <div class="flex justify-between text-stone-500 uppercase tracking-tighter text-xs">
                            <span>Subtotal</span>
                            <span id="subtotal-final">$0.00</span>
                        </div>
                        <div class="flex justify-between text-orange-500 font-bold uppercase tracking-tighter text-xs">
                            <span>Logística Metro</span>
                            <span id="envio-costo">$0.00</span>
                        </div>
                        <div class="flex justify-between text-2xl font-black text-white pt-6 border-t border-stone-900 mt-4">
                            <span class="italic">Total</span>
                            <span id="total-final">$0.00</span>
                        </div>
                    </div>

                    <button id="btn-pagar" class="w-full bg-white text-black hover:bg-orange-600 hover:text-white font-black py-5 rounded-full transition-all shadow-xl transform active:scale-95 cursor-pointer uppercase text-[10px] tracking-[0.3em]">
                        Confirmar Orden
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { carrito } from '../../store/carrito';

        const selectorEstado = document.getElementById('selector-estado') as HTMLSelectElement;
        const envioCostoTxt = document.getElementById('envio-costo');
        const subtotalTxt = document.getElementById('subtotal-final');
        const totalTxt = document.getElementById('total-final');
        const listaResumen = document.getElementById('lista-resumen');

        const COSTOS_ENVIO: Record<string, number> = {
            'CDMX': 0,
            'Edomex': 99
        };

        function actualizarResumen() {
            const items = Object.values(carrito.get());
            let subtotal = 0;

            if (listaResumen) listaResumen.innerHTML = '';

            items.forEach(item => {
                subtotal += item.precio * item.cantidad;
                listaResumen?.insertAdjacentHTML('beforeend', `
                    <div class="flex justify-between">
                        <span>${item.cantidad}x ${item.nombre}</span>
                        <span class="text-white">$${(item.precio * item.cantidad).toFixed(2)}</span>
                    </div>
                `);
            });

            const zona = selectorEstado.value || 'CDMX';
            const costoEnvio = COSTOS_ENVIO[zona] || 0;
            const total = subtotal + costoEnvio;

            if (subtotalTxt) subtotalTxt.innerText = `$${subtotal.toFixed(2)}`;
            if (envioCostoTxt) envioCostoTxt.innerText = `$${costoEnvio.toFixed(2)}`;
            if (totalTxt) totalTxt.innerText = `$${total.toFixed(2)}`;
        }

        selectorEstado?.addEventListener('change', actualizarResumen);
        actualizarResumen();

        document.getElementById('btn-pagar')?.addEventListener('click', async () => {
            const btn = document.getElementById('btn-pagar') as HTMLButtonElement;

            const nombre = (document.getElementById('input-nombre') as HTMLInputElement)?.value;
            const cp = (document.getElementById('input-cp') as HTMLInputElement)?.value;
            const direccion = (document.getElementById('input-direccion') as HTMLInputElement)?.value;
            const estado = selectorEstado.value;
            const userId = (document.getElementById('user-id') as HTMLInputElement)?.value;

            if (!nombre || !direccion || !cp || !estado) {
                alert("⚠️ Por favor, completa tu información de entrega.");
                return;
            }

            btn.disabled = true;
            btn.innerText = "Sincronizando con Tesorería...";

            const ordenData = {
                clienteNombre: nombre,
                estadoEnvio: estado,
                direccion: direccion,
                codigoPostal: cp,
                total: parseFloat(totalTxt?.innerText.replace('$', '') || '0'),
                items: Object.values(carrito.get()),
                userId: userId || null // Aquí vinculamos la orden al usuario real
            };

            try {
                const response = await fetch('/api/ordenes', {
                    method: 'POST',
                    body: JSON.stringify(ordenData),
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    alert("✅ ¡Pago Exitoso! Tu orden institucional ha sido registrada.");
                    carrito.set({});
                    window.location.href = "/";
                } else {
                    throw new Error("Rechazo de servidor");
                }
            } catch (error) {
                alert("❌ Fallo en la conexión. Reintenta.");
                btn.disabled = false;
                btn.innerText = "CONFIRMAR ORDEN";
            }
        });
    </script>
</Layout>