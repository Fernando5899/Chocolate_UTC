---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

// 1. EL CADENERO (Gatekeeper)
const session = await getSession(Astro.request);

// Si no hay sesión activa, abortamos la carga de la página y lo mandamos al Login
if (!session) {
    return Astro.redirect('/cuenta/login');
}

// 2. Si pasó el cadenero, buscamos sus datos en la base de datos
const usuario = await prisma.user.findUnique({
    where: { email: session.user?.email || '' }
});
---

<Layout title="Finalizar Pedido | Museo">
    <div class="max-w-6xl mx-auto px-8 py-20 transition-colors duration-500">
        <header class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-10 transition-colors duration-500">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-sm font-bold block mb-4">Proceso de Pago</span>
            <h1 class="text-6xl font-black italic text-stone-900 dark:text-white transition-colors duration-500">Finalizar Pedido</h1>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

            <div class="lg:col-span-2 space-y-8">

                <section class="bg-white dark:bg-[#110e0d] p-10 md:p-12 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-colors duration-500">
                    <h2 class="text-2xl font-bold italic text-stone-900 dark:text-white mb-8 flex items-center gap-3 border-b border-stone-100 dark:border-stone-800/80 pb-6 transition-colors duration-500">
                        <span class="text-orange-500">📍</span> Datos de Entrega Autorizados
                    </h2>

                    <form id="form-checkout" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <input type="hidden" id="user-id" value={usuario?.id} />

                        <div>
                            <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Nombre del Titular</label>
                            <input type="text" id="input-nombre" value={usuario?.name} required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all" />
                        </div>

                        <div>
                            <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Correo de Recibo (Verificado)</label>
                            <input type="email" id="input-email" value={session.user?.email} readonly class="w-full bg-stone-100 dark:bg-[#0a0807] border border-stone-200 dark:border-stone-800/50 p-4 rounded-2xl outline-none text-base text-stone-500 dark:text-stone-600 cursor-not-allowed transition-all" title="Tu correo está vinculado a Google y no puede ser modificado aquí." />
                        </div>

                        <div>
                            <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Entidad</label>
                            <select id="selector-estado" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white appearance-none transition-all">
                                <option value="" disabled selected>Selecciona...</option>
                                <option value="CDMX" selected={usuario?.estado === 'CDMX'}>Ciudad de México</option>
                                <option value="Edomex" selected={usuario?.estado === 'Edomex'}>Estado de México</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Código Postal</label>
                            <input type="text" id="input-cp" value={usuario?.codigoPostal} maxlength="5" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Dirección Completa</label>
                            <input type="text" id="input-direccion" value={usuario?.direccion} required placeholder="Calle, Número, Colonia..." class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all" />
                        </div>
                    </form>
                </section>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-stone-50 dark:bg-[#0c0a09] p-10 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-2xl sticky top-32 transition-colors duration-500">
                    <h2 class="text-2xl font-bold italic text-stone-900 dark:text-white mb-8 border-b border-stone-200 dark:border-stone-800 pb-6 transition-colors duration-500">Resumen</h2>

                    <div class="space-y-4 text-stone-600 dark:text-stone-400 text-sm mb-10 font-serif" id="lista-resumen">
                    </div>

                    <div class="space-y-4 border-t border-stone-200 dark:border-stone-800 pt-8 mb-10 transition-colors duration-500">
                        <div class="flex justify-between text-stone-500 uppercase tracking-widest text-[10px] font-bold">
                            <span>Subtotal</span>
                            <span id="subtotal-final" class="text-stone-900 dark:text-white text-sm font-black">$0.00</span>
                        </div>
                        <div class="flex justify-between text-orange-600 dark:text-orange-500 uppercase tracking-widest text-[10px] font-bold">
                            <span>Logística Metro</span>
                            <span id="envio-costo" class="text-sm font-black">$0.00</span>
                        </div>
                        <div class="flex justify-between items-center pt-8 border-t border-stone-200 dark:border-stone-800 mt-6 transition-colors duration-500">
                            <span class="text-sm uppercase tracking-widest text-stone-500 font-bold">Total</span>
                            <span id="total-final" class="text-4xl font-black text-stone-900 dark:text-white">$0.00</span>
                        </div>
                    </div>

                    <button id="btn-pagar" class="w-full bg-stone-900 dark:bg-white text-white dark:text-black hover:bg-orange-600 hover:dark:bg-orange-500 hover:text-white transition-all shadow-xl font-black py-5 rounded-full transform active:scale-95 cursor-pointer uppercase text-[10px] tracking-[0.3em]">
                        Confirmar Orden Segura
                    </button>
                </div>
            </div>

        </div>
    </div>

    <script>
        import { carrito } from '../../store/carrito';

        const selectorEstado = document.getElementById('selector-estado') as HTMLSelectElement;
        const envioCostoTxt = document.getElementById('envio-costo');
        const subtotalTxt = document.getElementById('subtotal-final');
        const totalTxt = document.getElementById('total-final');
        const listaResumen = document.getElementById('lista-resumen');

        const COSTOS_ENVIO: Record<string, number> = {
            'CDMX': 0,
            'Edomex': 99
        };

        function actualizarResumen() {
            const items = Object.values(carrito.get());
            let subtotal = 0;

            if (listaResumen) listaResumen.innerHTML = '';

            items.forEach(item => {
                subtotal += item.precio * item.cantidad;
                listaResumen?.insertAdjacentHTML('beforeend', `
                    <div class="flex justify-between items-center group">
                        <span class="italic">• ${item.cantidad}x ${item.nombre}</span>
                        <span class="text-stone-900 dark:text-white font-bold not-italic group-hover:text-orange-500 transition-colors">$${(item.precio * item.cantidad).toFixed(2)}</span>
                    </div>
                `);
            });

            const zona = selectorEstado?.value || 'CDMX';
            const costoEnvio = COSTOS_ENVIO[zona] || 0;
            const total = subtotal + costoEnvio;

            if (subtotalTxt) subtotalTxt.innerText = `$${subtotal.toFixed(2)}`;
            if (envioCostoTxt) envioCostoTxt.innerText = costoEnvio === 0 ? 'GRATIS' : `$${costoEnvio.toFixed(2)}`;
            if (totalTxt) totalTxt.innerText = `$${total.toFixed(2)}`;
        }

        selectorEstado?.addEventListener('change', actualizarResumen);
        actualizarResumen();

        document.getElementById('btn-pagar')?.addEventListener('click', async () => {
            const btn = document.getElementById('btn-pagar') as HTMLButtonElement;

            const nombre = (document.getElementById('input-nombre') as HTMLInputElement)?.value;
            const email = (document.getElementById('input-email') as HTMLInputElement)?.value;
            const cp = (document.getElementById('input-cp') as HTMLInputElement)?.value;
            const direccion = (document.getElementById('input-direccion') as HTMLInputElement)?.value;
            const estado = selectorEstado?.value;
            const userId = (document.getElementById('user-id') as HTMLInputElement)?.value;

            if (!nombre || !direccion || !cp || !estado) {
                alert("⚠️ Por favor, completa tu información de entrega.");
                return;
            }

            btn.disabled = true;
            btn.innerText = "PROCESANDO...";

            const ordenData = {
                clienteNombre: nombre,
                email: email,
                estadoEnvio: estado,
                direccion: direccion,
                codigoPostal: cp,
                total: parseFloat(totalTxt?.innerText.replace('$', '') || '0'),
                items: Object.values(carrito.get()),
                userId: userId
            };

            try {
                const response = await fetch('/api/ordenes', {
                    method: 'POST',
                    body: JSON.stringify(ordenData),
                    headers: { 'Content-Type': 'application/json' }
                });

                const result = await response.json();

                if (response.ok) {
                    carrito.set({});
                    window.location.href = `/tienda/gracias?orden=${result.orden.id}`;
                } else {
                    throw new Error(result.error || "El servidor rechazó la orden.");
                }
            } catch (error) {
                const mensajeError = error instanceof Error ? error.message : "Error desconocido de red.";
                alert(`❌ Ocurrió un problema: ${mensajeError}`);
                btn.disabled = false;
                btn.innerText = "CONFIRMAR ORDEN SEGURA";
            }
        });
    </script>
</Layout>