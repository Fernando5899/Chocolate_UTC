---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 1. Consultamos la base de datos (Usando el modelo Chocolate original)
const chocolates = await prisma.chocolate.findMany({
    include: {
        categoria: true
    },
    orderBy: {
        nombre: 'asc'
    }
});
---

<Layout title="Catálogo de Chocolates | Museo">
    <div class="max-w-7xl mx-auto px-8 py-20 w-full transition-colors duration-500">

        <header class="mb-16 text-center transition-colors duration-500">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-[10px] font-bold block mb-4">La Colección Real</span>
            <h1 class="text-5xl md:text-7xl font-black italic text-stone-900 dark:text-white mb-6 transition-colors duration-500 tracking-tighter">
                Galería de Sabores
            </h1>
            <p class="text-lg text-stone-500 dark:text-stone-400 max-w-2xl mx-auto font-serif italic">
                "Desde los cacaos más intensos hasta las mezclas más suaves, diseñados para despertar tus sentidos y honrar nuestra tradición."
            </p>
        </header>

        <div class="flex flex-wrap justify-center gap-12">
            {chocolates.map((choco) => (
                    <div class={`bg-white dark:bg-[#110e0d] p-8 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-all duration-500 flex flex-col group overflow-hidden w-full md:w-[calc(50%-3rem)] lg:w-[calc(33.33%-3rem)] max-w-[420px] ${choco.stock > 0 ? 'hover:border-orange-500 dark:hover:border-orange-500 hover:-translate-y-3' : 'opacity-60 grayscale'}`}>

                        <div class="relative aspect-square mb-8 overflow-hidden rounded-[32px] bg-stone-100 dark:bg-[#0c0a09] border border-stone-100 dark:border-stone-900">
                            {choco.imagenUrl ? (
                                    <img
                                            src={choco.imagenUrl}
                                            alt={choco.nombre}
                                            class={`w-full h-full object-cover transition-all duration-1000 ${choco.stock > 0 ? 'grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110' : 'grayscale opacity-40'}`}
                                    />
                            ) : (
                                    <div class="w-full h-full flex items-center justify-center">
                                        <span class="text-6xl opacity-20 grayscale">🍫</span>
                                    </div>
                            )}

                            <span class="absolute top-5 right-5 bg-white/90 dark:bg-black/80 backdrop-blur-md text-stone-900 dark:text-white text-[9px] font-black px-4 py-2 rounded-full uppercase tracking-widest shadow-sm z-10">
                            {choco.categoria?.nombre || 'Especialidad'}
                        </span>
                        </div>

                        <div class="flex flex-col flex-grow">
                            <div class="flex justify-between items-start mb-3 gap-4">
                                <h3 class="text-2xl font-bold font-serif italic text-stone-900 dark:text-white leading-tight line-clamp-1 break-all" title={choco.nombre}>
                                    {choco.nombre}
                                </h3>

                                <span class={`text-[8px] uppercase tracking-[0.2em] font-black px-2 py-1 rounded-md border shrink-0 ${choco.stock > 0 ? 'border-green-200 text-green-700 bg-green-50 dark:border-green-900/50 dark:text-green-400 dark:bg-green-900/20' : 'border-red-200 text-red-700 bg-red-50 dark:border-red-900/50 dark:text-red-400 dark:bg-red-900/20'}`}>
                                {choco.stock > 0 ? `${choco.stock} Disponibles` : 'Agotado'}
                            </span>
                            </div>

                            <p class="text-stone-500 dark:text-stone-400 text-sm mb-8 flex-grow font-light leading-relaxed line-clamp-2 italic">
                                {choco.descripcion}
                            </p>

                            <div class="flex justify-between items-center mt-auto pt-6 border-t border-stone-100 dark:border-stone-800 transition-colors">
                                <div class="flex flex-col">
                                    <span class="text-[9px] font-black text-stone-400 uppercase tracking-widest">Precio</span>
                                    <span class="text-3xl font-black text-stone-900 dark:text-white">
                                    ${Number(choco.precio).toFixed(2)}
                                </span>
                                </div>

                                {choco.stock > 0 ? (
                                        <button
                                                class="btn-agregar bg-stone-900 dark:bg-white text-white dark:text-black px-8 py-4 rounded-full font-black uppercase text-[10px] tracking-widest hover:bg-orange-600 hover:dark:bg-orange-500 hover:text-white transition-all shadow-xl active:scale-95 cursor-pointer shrink-0"
                                                data-id={choco.id}
                                                data-nombre={choco.nombre}
                                                data-precio={Number(choco.precio).toFixed(2)}
                                                data-imagen={choco.imagenUrl || ''}
                                                data-stock={choco.stock}
                                        >
                                            Agregar 🛒
                                        </button>
                                ) : (
                                        <span class="text-stone-400 dark:text-stone-600 font-bold text-[9px] uppercase tracking-widest bg-stone-100 dark:bg-stone-900/50 px-6 py-4 rounded-full border border-stone-200 dark:border-stone-800 cursor-not-allowed italic">Temporalmente Agotado</span>
                                )}
                            </div>
                        </div>
                    </div>
            ))}
        </div>

        {chocolates.length === 0 && (
                <div class="text-center p-20 bg-white/50 dark:bg-[#110e0d]/50 backdrop-blur-md rounded-[40px] border border-stone-200 dark:border-stone-800 border-dashed mt-10">
                    <span class="text-6xl mb-6 block opacity-30 grayscale">👨‍🍳</span>
                    <h2 class="text-3xl font-black italic text-stone-900 dark:text-white mb-2 uppercase tracking-tighter">Catálogo en preparación</h2>
                    <p class="text-stone-500 dark:text-stone-400 italic">Nuestros maestros chocolateros están seleccionando las mejores semillas para la siguiente exhibición.</p>
                </div>
        )}
    </div>

    <script>
        import { carrito } from '../../store/carrito';
        import { agregarAlCarrito } from '../../store/carrito';

        const botones = document.querySelectorAll('.btn-agregar');

        botones.forEach((boton) => {
            boton.addEventListener('click', () => {
                const id = boton.getAttribute('data-id');
                const nombre = boton.getAttribute('data-nombre');
                const precio = parseFloat(boton.getAttribute('data-precio') || '0');
                const imagenUrl = boton.getAttribute('data-imagen');
                const stockDisponible = parseInt(boton.getAttribute('data-stock') || '0');

                if (id && nombre) {
                    const itemsActuales = carrito.get();
                    const cantidadEnCarrito = itemsActuales[id]?.cantidad || 0;

                    if (cantidadEnCarrito >= stockDisponible) {
                        alert(`⚠️ Inventario Máximo: Solo contamos con ${stockDisponible} unidades de ${nombre} en nuestra reserva.`);
                        return;
                    }

                    agregarAlCarrito({ id, nombre, precio, imagenUrl });

                    // Feedback visual premium
                    const originalText = boton.innerHTML;
                    boton.innerHTML = '¡Agregado! ✅';
                    boton.classList.add('bg-green-600', 'text-white');
                    boton.classList.remove('bg-stone-900', 'dark:bg-white', 'dark:text-black');

                    setTimeout(() => {
                        boton.innerHTML = originalText;
                        boton.classList.remove('bg-green-600', 'text-white');
                        boton.classList.add('bg-stone-900', 'dark:bg-white', 'dark:text-black');
                    }, 1500);
                }
            });
        });
    </script>
</Layout>