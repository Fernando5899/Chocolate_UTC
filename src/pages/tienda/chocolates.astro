---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 1. Consultamos la base de datos
const chocolates = await prisma.chocolate.findMany({
    include: {
        categoria: true
    },
    orderBy: {
        nombre: 'asc'
    }
});
---

<Layout title="Catálogo de Chocolates | Museo">
    <div class="max-w-7xl mx-auto px-8 py-20 w-full transition-colors duration-500">

        <header class="mb-16 text-center transition-colors duration-500">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-sm font-bold block mb-4">La Colección</span>
            <h1 class="text-5xl md:text-6xl font-black italic text-stone-900 dark:text-white mb-6 transition-colors duration-500">
                Catálogo Exclusivo
            </h1>
            <p class="text-lg text-stone-600 dark:text-stone-400 max-w-2xl mx-auto transition-colors duration-500">
                Descubre nuestra selección artesanal. Desde los cacaos más intensos hasta las mezclas más suaves, diseñados para despertar tus sentidos.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {chocolates.map((choco) => (
                    <div class={`bg-white dark:bg-[#110e0d] p-8 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-all duration-300 flex flex-col group overflow-hidden ${choco.stock > 0 ? 'hover:border-orange-500 dark:hover:border-orange-500 hover:-translate-y-2' : 'opacity-70 grayscale'}`}>

                        <div class="relative aspect-square mb-6 overflow-hidden rounded-3xl bg-stone-100 dark:bg-[#0c0a09]">
                            {choco.imagenUrl ? (
                                    <img
                                            src={choco.imagenUrl}
                                            alt={choco.nombre}
                                            class={`w-full h-full object-cover transition-all duration-700 ${choco.stock > 0 ? 'grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105' : 'grayscale opacity-40'}`}
                                    />
                            ) : (
                                    <div class="w-full h-full flex items-center justify-center">
                                        <span class="text-6xl grayscale opacity-30">🍫</span>
                                    </div>
                            )}

                            <span class="absolute top-4 right-4 bg-orange-100 text-orange-800 dark:bg-orange-900/50 dark:text-orange-300 text-[10px] font-bold px-4 py-1.5 rounded-full uppercase tracking-widest shadow-sm z-10 backdrop-blur-sm">
                            {choco.categoria?.nombre || 'General'}
                        </span>
                        </div>

                        <div class="flex flex-col flex-grow">
                            <div class="flex justify-between items-start mb-2 gap-4">
                                <h3 class="text-2xl font-bold font-serif text-stone-900 dark:text-white leading-tight transition-colors duration-500 line-clamp-1 break-all" title={choco.nombre}>
                                    {choco.nombre}
                                </h3>

                                <span class={`text-[9px] uppercase tracking-widest font-bold px-2 py-1 rounded-md border shrink-0 ${choco.stock > 0 ? 'border-green-200 text-green-700 dark:border-green-900 dark:text-green-400 bg-green-50 dark:bg-green-900/20' : 'border-red-200 text-red-700 dark:border-red-900 dark:text-red-400 bg-red-50 dark:bg-red-900/20'}`}>
                                {choco.stock > 0 ? `${choco.stock} en stock` : 'Agotado'}
                            </span>
                            </div>

                            <p class="text-stone-600 dark:text-stone-400 text-sm mb-8 flex-grow transition-colors duration-500 line-clamp-2 break-words min-h-[40px]">
                                {choco.descripcion}
                            </p>

                            <div class="flex justify-between items-center mt-auto pt-6 border-t border-stone-100 dark:border-stone-800/80 transition-colors duration-500">
                                <span class="text-4xl font-black text-stone-900 dark:text-white transition-colors duration-500 shrink-0">
                                    ${choco.precio.toString()}
                                </span>

                                {choco.stock > 0 ? (
                                        <button
                                                class="btn-agregar bg-stone-900 dark:bg-white text-white dark:text-black px-8 py-4 rounded-full font-bold uppercase text-[10px] tracking-widest hover:bg-orange-600 hover:dark:bg-orange-500 hover:text-white transition-all shadow-lg active:scale-95 cursor-pointer shrink-0"
                                                data-id={choco.id}
                                                data-nombre={choco.nombre}
                                                data-precio={choco.precio.toString()}
                                                data-imagen={choco.imagenUrl || ''}
                                                data-stock={choco.stock}
                                        >
                                            Agregar 🛒
                                        </button>
                                ) : (
                                        <span class="text-stone-500 dark:text-stone-500 font-bold text-[10px] uppercase tracking-widest bg-stone-100 dark:bg-stone-900/50 px-6 py-4 rounded-full border border-stone-200 dark:border-stone-800 cursor-not-allowed">Sin Inventario</span>
                                )}
                            </div>
                        </div>
                    </div>
            ))}
        </div>

        {chocolates.length === 0 && (
                <div class="text-center p-16 bg-white/50 dark:bg-[#110e0d]/50 backdrop-blur-md rounded-[40px] border border-stone-200 dark:border-stone-800 border-dashed transition-colors duration-500 mt-10">
                    <span class="text-6xl mb-6 block opacity-50 grayscale">👨‍🍳</span>
                    <h2 class="text-3xl font-bold italic text-stone-900 dark:text-white mb-2">Catálogo en preparación</h2>
                    <p class="text-stone-500 dark:text-stone-400">Nuestros maestros chocolateros están preparando nuevas delicias para la galería.</p>
                </div>
        )}
    </div>

    <script>
        import { carrito } from '../../store/carrito';
        import { agregarAlCarrito } from '../../store/carrito';

        const botones = document.querySelectorAll('.btn-agregar');

        botones.forEach((boton) => {
            boton.addEventListener('click', () => {
                const id = boton.getAttribute('data-id');
                const nombre = boton.getAttribute('data-nombre');
                const precio = parseFloat(boton.getAttribute('data-precio') || '0');
                const imagenUrl = boton.getAttribute('data-imagen');

                const stockDisponible = parseInt(boton.getAttribute('data-stock') || '0');

                if (id && nombre) {
                    const itemsActuales = carrito.get();
                    const cantidadEnCarrito = itemsActuales[id]?.cantidad || 0;

                    if (cantidadEnCarrito >= stockDisponible) {
                        alert(`⚠️ Has alcanzado el límite. Solo contamos con ${stockDisponible} unidades de ${nombre} en el museo.`);
                        return;
                    }

                    agregarAlCarrito({ id, nombre, precio, imagenUrl });

                    const originalText = boton.innerHTML;
                    boton.innerHTML = '¡Agregado! ✅';
                    boton.classList.replace('bg-stone-900', 'bg-green-600');
                    boton.classList.replace('dark:bg-white', 'dark:bg-green-500');
                    boton.classList.add('text-white');

                    setTimeout(() => {
                        boton.innerHTML = originalText;
                        boton.classList.replace('bg-green-600', 'bg-stone-900');
                        boton.classList.replace('dark:bg-green-500', 'dark:bg-white');
                        boton.classList.remove('text-white');
                    }, 1500);
                }
            });
        });
    </script>
</Layout>