---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 1. Consultamos la base de datos (Traemos chocolates y sus categorías)
const chocolates = await prisma.chocolate.findMany({
    include: {
        categoria: true
    },
    orderBy: {
        nombre: 'asc'
    }
});
---

<Layout title="Catálogo de Chocolates | Museo">
    <div class="mb-12 text-center transition-colors duration-500">
        <h1 class="text-4xl md:text-5xl font-black italic text-stone-900 dark:text-white mb-4 transition-colors duration-500">
            Catálogo Exclusivo
        </h1>
        <p class="text-lg text-stone-600 dark:text-stone-400 max-w-2xl mx-auto transition-colors duration-500">
            Descubre nuestra selección artesanal. Desde los cacaos más intensos hasta las mezclas más suaves, diseñados para despertar tus sentidos.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {chocolates.map((choco) => (
                <div class="bg-white dark:bg-[#110e0d] p-6 rounded-3xl border border-stone-200 dark:border-stone-800 shadow-xl transition-all duration-300 hover:border-orange-500 dark:hover:border-orange-500 hover:-translate-y-1 flex flex-col group">

                    <div class="relative aspect-square mb-6 overflow-hidden rounded-2xl bg-stone-100 dark:bg-[#0c0a09]">
                        {choco.imagenUrl ? (
                                <img
                                        src={choco.imagenUrl}
                                        alt={choco.nombre}
                                        class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                                />
                        ) : (
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="text-6xl group-hover:scale-110 transition-transform duration-300 grayscale opacity-50">🍫</span>
                                </div>
                        )}

                        <span class="absolute top-4 right-4 bg-orange-100 text-orange-800 dark:bg-orange-900/50 dark:text-orange-300 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest shadow-sm z-10 backdrop-blur-sm">
                        {choco.categoria.nombre}
                    </span>
                    </div>

                    <div class="flex flex-col flex-grow">
                        <h3 class="text-2xl font-bold font-serif text-stone-900 dark:text-white leading-tight mb-2 transition-colors duration-500">{choco.nombre}</h3>
                        <p class="text-stone-600 dark:text-stone-400 text-sm mb-6 flex-grow transition-colors duration-500">{choco.descripcion}</p>

                        <div class="flex justify-between items-center mt-auto pt-4 border-t border-stone-100 dark:border-stone-800/50 transition-colors duration-500">
                            <span class="text-2xl font-black text-stone-900 dark:text-white transition-colors duration-500">${choco.precio.toString()}</span>

                            {choco.stock > 0 ? (
                                    <button
                                            class="btn-agregar bg-orange-600 hover:bg-orange-500 text-white font-bold py-2.5 px-6 rounded-full transition-all text-[10px] uppercase tracking-widest shadow-md hover:shadow-orange-500/20 active:scale-95 cursor-pointer"
                                            data-id={choco.id}
                                            data-nombre={choco.nombre}
                                            data-precio={choco.precio.toString()}
                                            data-imagen={choco.imagenUrl || ''}
                                    >
                                        Agregar 🛒
                                    </button>
                            ) : (
                                    <span class="text-red-500 dark:text-red-400 font-bold text-[10px] uppercase tracking-widest bg-red-50 dark:bg-red-900/20 px-4 py-2.5 rounded-full border border-red-100 dark:border-red-900/50">Agotado</span>
                            )}
                        </div>
                    </div>
                </div>
        ))}
    </div>

    {chocolates.length === 0 && (
            <div class="text-center p-16 bg-white dark:bg-[#110e0d]/50 rounded-[40px] border border-stone-200 dark:border-stone-800 border-dashed transition-colors duration-500">
                <span class="text-6xl mb-6 block opacity-50 grayscale">👨‍🍳</span>
                <h2 class="text-3xl font-bold italic text-stone-900 dark:text-white mb-2">Catálogo en preparación</h2>
                <p class="text-stone-500 dark:text-stone-400">Nuestros maestros chocolateros están preparando nuevas delicias para la galería.</p>
            </div>
    )}

    <script>
        import { agregarAlCarrito } from '../../store/carrito';

        const botones = document.querySelectorAll('.btn-agregar');

        botones.forEach((boton) => {
            boton.addEventListener('click', () => {
                const id = boton.getAttribute('data-id');
                const nombre = boton.getAttribute('data-nombre');
                const precio = parseFloat(boton.getAttribute('data-precio') || '0');
                const imagenUrl = boton.getAttribute('data-imagen');

                if (id && nombre) {
                    agregarAlCarrito({ id, nombre, precio, imagenUrl });
                }

                const textoOriginal = boton.innerHTML;
                boton.innerHTML = '¡Agregado! ✅';
                boton.classList.replace('bg-orange-600', 'bg-green-600');
                boton.classList.replace('hover:bg-orange-500', 'hover:bg-green-500');

                setTimeout(() => {
                    boton.innerHTML = textoOriginal;
                    boton.classList.replace('bg-green-600', 'bg-orange-600');
                    boton.classList.replace('hover:bg-green-500', 'hover:bg-orange-500');
                }, 1000);
            });
        });
    </script>
</Layout>