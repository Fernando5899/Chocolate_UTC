---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 1. Consultamos la base de datos (Usando el modelo Chocolate original)
const chocolates = await prisma.chocolate.findMany({
    include: {
        categoria: true
    },
    orderBy: {
        nombre: 'asc'
    }
});
---

<Layout title="Catálogo de Chocolates | Museo">
    <div class="max-w-7xl mx-auto px-8 py-24 md:py-32 w-full transition-colors duration-500">

        <header class="mb-24 text-center max-w-3xl mx-auto transition-colors duration-500">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.5em] text-[10px] md:text-xs font-black mb-4 block">
                La Colección Real
            </span>
            <h1 class="text-6xl md:text-8xl font-serif italic font-black text-stone-900 dark:text-white mb-8 leading-[0.9]">
                Galería de Sabores
            </h1>
            <p class="text-lg md:text-xl text-stone-600 dark:text-stone-400 font-serif italic leading-relaxed">
                "Desde los cacaos más intensos hasta las mezclas más suaves, diseñados para despertar tus sentidos y honrar nuestra tradición."
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {chocolates.map((choco) => (
                <div class={`bg-white dark:bg-[#110e0d] p-8 md:p-10 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl transition-all duration-700 flex flex-col group overflow-hidden ${choco.stock > 0 ? 'hover:border-orange-500/50 hover:shadow-orange-900/10 hover:-translate-y-2' : 'opacity-60 grayscale'}`}>

                    <div class="relative aspect-square mb-8 overflow-hidden rounded-[30px] bg-stone-100 dark:bg-[#0c0a09] border border-stone-100 dark:border-stone-900">
                        {choco.imagenUrl ? (
                            <img
                                src={choco.imagenUrl}
                                alt={choco.nombre}
                                class={`w-full h-full object-cover transition-all duration-1000 ${choco.stock > 0 ? 'grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110' : 'grayscale opacity-40'}`}
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="text-7xl opacity-20 grayscale drop-shadow-sm">🍫</span>
                            </div>
                        )}

                        <span class="absolute top-5 right-5 bg-white/90 dark:bg-black/80 backdrop-blur-md text-stone-900 dark:text-white text-[9px] font-black px-5 py-2 rounded-full uppercase tracking-[0.3em] shadow-sm z-10 border border-stone-200 dark:border-stone-800">
                            {choco.categoria?.nombre || 'Especialidad'}
                        </span>
                    </div>

                    <div class="flex flex-col flex-grow">
                        
                        <div class="flex flex-col mb-4 gap-3">
                            <span class={`w-fit text-[8px] uppercase tracking-[0.3em] font-black px-3 py-1.5 rounded-full border ${choco.stock > 0 ? 'border-green-200 text-green-700 bg-green-50 dark:border-green-900/50 dark:text-green-400 dark:bg-green-900/20' : 'border-red-200 text-red-700 bg-red-50 dark:border-red-900/50 dark:text-red-400 dark:bg-red-900/20'}`}>
                                {choco.stock > 0 ? `${choco.stock} Unidades en Reserva` : 'Agotado'}
                            </span>
                            
                            <h3 class="text-3xl font-black font-serif italic text-stone-900 dark:text-white leading-tight drop-shadow-sm">
                                {choco.nombre}
                            </h3>
                        </div>

                        <p class="text-stone-500 dark:text-stone-400 text-sm mb-10 flex-grow font-serif italic leading-relaxed line-clamp-3">
                            {choco.descripcion}
                        </p>

                        <div class="flex justify-between items-center mt-auto pt-6 border-t border-stone-100 dark:border-stone-800 transition-colors">
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black text-stone-400 uppercase tracking-[0.4em] mb-1">Aporte</span>
                                <span class="text-3xl font-black text-stone-900 dark:text-white font-mono tracking-tighter">
                                    ${Number(choco.precio).toFixed(2)}
                                </span>
                            </div>

                            {choco.stock > 0 ? (
                                <button
                                    class="btn-agregar bg-stone-900 dark:bg-white text-white dark:text-black px-6 py-4 rounded-full font-black uppercase text-[10px] tracking-[0.2em] hover:bg-orange-600 hover:dark:bg-orange-600 hover:text-white transition-all shadow-xl active:scale-95 cursor-pointer shrink-0"
                                    data-id={choco.id}
                                    data-nombre={choco.nombre}
                                    data-precio={Number(choco.precio).toFixed(2)}
                                    data-imagen={choco.imagenUrl || ''}
                                    data-stock={choco.stock}
                                >
                                    Añadir 🛍️
                                </button>
                            ) : (
                                <span class="text-stone-400 dark:text-stone-600 font-black text-[9px] uppercase tracking-[0.2em] bg-stone-100 dark:bg-[#0c0a09] px-6 py-4 rounded-full border border-stone-200 dark:border-stone-800 cursor-not-allowed text-center">
                                    Agotado
                                </span>
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>

        {chocolates.length === 0 && (
            <div class="text-center p-20 bg-white/50 dark:bg-[#110e0d]/50 backdrop-blur-md rounded-[50px] border border-stone-200 dark:border-stone-800 border-dashed mt-10">
                <span class="text-7xl mb-8 block opacity-30 grayscale">👨‍🍳</span>
                <h2 class="text-4xl font-black font-serif italic text-stone-900 dark:text-white mb-4">Catálogo en preparación</h2>
                <p class="text-stone-500 dark:text-stone-400 font-serif italic text-lg max-w-md mx-auto">
                    Nuestros maestros chocolateros están seleccionando las mejores semillas para la siguiente exhibición.
                </p>
            </div>
        )}
    </div>

    <script>
        import { carrito } from '../../store/carrito';
        import { agregarAlCarrito } from '../../store/carrito';

        const botones = document.querySelectorAll('.btn-agregar');

        botones.forEach((boton) => {
            boton.addEventListener('click', () => {
                const id = boton.getAttribute('data-id');
                const nombre = boton.getAttribute('data-nombre');
                const precio = parseFloat(boton.getAttribute('data-precio') || '0');
                const imagenUrl = boton.getAttribute('data-imagen');
                const stockDisponible = parseInt(boton.getAttribute('data-stock') || '0');

                if (id && nombre) {
                    const itemsActuales = carrito.get();
                    const cantidadEnCarrito = itemsActuales[id]?.cantidad || 0;

                    if (cantidadEnCarrito >= stockDisponible) {
                        alert(`⚠️ Inventario Máximo: Solo contamos con ${stockDisponible} unidades de "${nombre}" en nuestra reserva.`);
                        return;
                    }

                    agregarAlCarrito({ id, nombre, precio, imagenUrl });

                    // Feedback visual premium
                    const originalText = boton.innerHTML;
                    boton.innerHTML = 'En Reserva ✅';
                    boton.classList.add('bg-orange-500', 'text-white', 'border-transparent');
                    boton.classList.remove('bg-stone-900', 'dark:bg-white', 'dark:text-black');

                    setTimeout(() => {
                        boton.innerHTML = originalText;
                        boton.classList.remove('bg-orange-500', 'text-white', 'border-transparent');
                        boton.classList.add('bg-stone-900', 'dark:bg-white', 'dark:text-black');
                    }, 1500);
                }
            });
        });
    </script>
</Layout>