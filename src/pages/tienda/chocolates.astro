---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 1. Consultamos la base de datos (Traemos chocolates y sus categorías)
const chocolates = await prisma.chocolate.findMany({
    include: {
        categoria: true
    },
    orderBy: {
        nombre: 'asc'
    }
});
---

<Layout title="Catálogo de Chocolates | Museo">
    <div class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold text-stone-800 mb-4">
            Catálogo Exclusivo
        </h1>
        <p class="text-lg text-stone-600 max-w-2xl mx-auto">
            Descubre nuestra selección artesanal. Desde los cacaos más intensos hasta las mezclas más suaves, diseñados para despertar tus sentidos.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {chocolates.map((choco) => (
                <div class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden hover:shadow-xl transition-all duration-300 group flex flex-col">

                    <div class="h-48 bg-stone-100 flex items-center justify-center relative overflow-hidden">
                        {choco.imagenUrl ? (
                                <img
                                        src={choco.imagenUrl}
                                        alt={choco.nombre}
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                />
                        ) : (
                                <span class="text-5xl group-hover:scale-110 transition-transform duration-300">🍫</span>
                        )}

                        <span class="absolute top-4 right-4 bg-orange-100 text-orange-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide shadow-sm">
                        {choco.categoria.nombre}
                    </span>
                    </div>

                    <div class="p-6 flex flex-col flex-grow">
                        <h3 class="text-xl font-bold text-stone-800 leading-tight mb-2">{choco.nombre}</h3>
                        <p class="text-stone-600 text-sm mb-6 flex-grow">{choco.descripcion}</p>

                        <div class="flex justify-between items-center mt-auto pt-4 border-t border-stone-100">
                            <span class="text-2xl font-black text-stone-900">${choco.precio}</span>

                            {choco.stock > 0 ? (
                                    <button
                                            class="btn-agregar bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-5 rounded-lg transition-all text-sm shadow-md active:scale-95 cursor-pointer"
                                            data-id={choco.id}
                                            data-nombre={choco.nombre}
                                            data-precio={choco.precio}
                                            data-imagen={choco.imagenUrl || ''}
                                    >
                                        Agregar 🛒
                                    </button>
                            ) : (
                                    <span class="text-red-500 font-bold text-sm bg-red-50 px-3 py-2 rounded-lg">Agotado</span>
                            )}
                        </div>
                    </div>
                </div>
        ))}
    </div>

    {chocolates.length === 0 && (
            <div class="text-center py-20 bg-white rounded-2xl border border-stone-200 border-dashed">
                <span class="text-4xl mb-4 block">👨‍🍳</span>
                <h2 class="text-2xl font-bold text-stone-700 mb-2">Catálogo en preparación</h2>
                <p class="text-stone-500">Nuestros maestros chocolateros están preparando nuevas delicias.</p>
            </div>
    )}

    <script>
        import { agregarAlCarrito } from '../../store/carrito';

        // Buscamos todos los botones que tengan la clase 'btn-agregar'
        const botones = document.querySelectorAll('.btn-agregar');

        botones.forEach((boton) => {
            boton.addEventListener('click', () => {
                // 1. Extraemos los datos del HTML del botón
                const id = boton.getAttribute('data-id');
                const nombre = boton.getAttribute('data-nombre');
                const precio = parseFloat(boton.getAttribute('data-precio') || '0');
                const imagenUrl = boton.getAttribute('data-imagen');

                // 2. Mandamos la orden al "Cerebro" (Nano Stores)
                if (id && nombre) {
                    agregarAlCarrito({ id, nombre, precio, imagenUrl });
                }

                // 3. Efecto visual: Cambiamos el botón temporalmente
                const textoOriginal = boton.innerHTML;
                boton.innerHTML = '¡Agregado! ✅';
                boton.classList.replace('bg-orange-600', 'bg-green-600');
                boton.classList.replace('hover:bg-orange-700', 'hover:bg-green-700');

                setTimeout(() => {
                    boton.innerHTML = textoOriginal;
                    boton.classList.replace('bg-green-600', 'bg-orange-600');
                    boton.classList.replace('hover:bg-green-700', 'hover:bg-orange-700');
                }, 1000);
            });
        });
    </script>
</Layout>