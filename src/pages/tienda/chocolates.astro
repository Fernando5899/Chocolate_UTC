---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 1. Consultamos la base de datos (Traemos todos los chocolates y el nombre de su categoría)
const chocolates = await prisma.chocolate.findMany({
    include: {
        categoria: true
    },
    orderBy: {
        nombre: 'asc'
    }
});
---

<Layout title="Catálogo de Chocolates | Museo">
    <div class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold text-stone-800 mb-4">
            Catálogo Exclusivo
        </h1>
        <p class="text-lg text-stone-600 max-w-2xl mx-auto">
            Descubre nuestra selección artesanal. Desde los cacaos más intensos hasta las mezclas más suaves, diseñados para despertar tus sentidos.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {chocolates.map((choco) => (
                <div class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden hover:shadow-xl transition-all duration-300 group flex flex-col">
                    <div class="h-48 bg-stone-100 flex items-center justify-center relative overflow-hidden">
                        {choco.imagenUrl ? (
                            /* Si el chocolate tiene una imagen en la BD, la mostramos */
                                <img
                                        src={choco.imagenUrl}
                                        alt={choco.nombre}
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                />
                        ) : (
                            /* Si no tiene imagen, dejamos el emoji como respaldo (fallback) */
                                <span class="text-5xl group-hover:scale-110 transition-transform duration-300">🍫</span>
                        )}

                        <span class="absolute top-4 right-4 bg-orange-100 text-orange-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
        {choco.categoria.nombre}
    </span>
                    </div>

                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-xl font-bold text-stone-800 leading-tight">{choco.nombre}</h3>
                        </div>

                        <p class="text-stone-600 text-sm mb-6 flex-grow">{choco.descripcion}</p>

                        <div class="flex justify-between items-center mt-auto pt-4 border-t border-stone-100">
                            <span class="text-2xl font-black text-stone-900">${choco.precio}</span>

                            {choco.stock > 0 ? (
                                    <button class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-5 rounded-lg transition-colors text-sm shadow-md">
                                        Agregar 🛒
                                    </button>
                            ) : (
                                    <span class="text-red-500 font-bold text-sm bg-red-50 px-3 py-2 rounded-lg">Agotado</span>
                            )}
                        </div>
                    </div>
                </div>
        ))}
    </div>

    {chocolates.length === 0 && (
            <div class="text-center py-20 bg-white rounded-2xl border border-stone-200 border-dashed">
                <span class="text-4xl mb-4 block">👨‍🍳</span>
                <h2 class="text-2xl font-bold text-stone-700 mb-2">Catálogo en preparación</h2>
                <p class="text-stone-500">Nuestros maestros chocolateros están preparando nuevas delicias.</p>
            </div>
    )}
</Layout>