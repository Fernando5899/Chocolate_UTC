---
import Layout from '../../layouts/Layout.astro';

// Obtenemos el ID de la orden que viene en la URL (?orden=...)
const idOrden = Astro.url.searchParams.get('orden');

if (!idOrden) return Astro.redirect('/tienda/chocolates');

// URL que abrirá el QR (Cámbiala por tu dominio de Vercel cuando despliegues)
const urlTicket = `https://chocolate-utc.vercel.app/ticket/${idOrden}`;
---

<Layout title="¡Orden Confirmada! | Museo de Chocolate">
    <div class="min-h-screen flex items-center justify-center bg-stone-50 dark:bg-[#0c0a09] px-6 py-24 transition-colors duration-500">
        <div class="max-w-md w-full text-center">

            <div class="mb-14">
                <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-[10px] font-black block mb-4">Transacción Exitosa</span>
                <h1 class="text-5xl md:text-6xl font-serif italic font-black text-stone-900 dark:text-white mb-6 tracking-tight drop-shadow-sm">¡Orden Confirmada!</h1>
                <p class="text-stone-500 dark:text-stone-400 text-base font-serif italic max-w-sm mx-auto leading-relaxed">
                    Tu expedición ha sido registrada en nuestros archivos. Presenta este código en la entrada del museo.
                </p>
            </div>

            <div class="bg-white dark:bg-[#110e0d] p-10 md:p-14 rounded-[50px] shadow-2xl border border-stone-200 dark:border-stone-800 mb-12 transition-colors duration-500 relative overflow-hidden">
                
                <div class="absolute -top-6 -left-6 w-12 h-12 bg-stone-50 dark:bg-[#0c0a09] rounded-full border-b border-r border-stone-200 dark:border-stone-800 transition-colors duration-500"></div>
                <div class="absolute -top-6 -right-6 w-12 h-12 bg-stone-50 dark:bg-[#0c0a09] rounded-full border-b border-l border-stone-200 dark:border-stone-800 transition-colors duration-500"></div>

                <span class="text-[10px] uppercase tracking-[0.4em] font-black text-stone-400 block mb-8 mt-2">Pase de Visitante</span>

                <div class="flex justify-center mb-8 bg-white p-5 rounded-[30px] inline-block mx-auto border border-stone-200 shadow-sm">
                    <canvas id="qrcode-canvas"></canvas>
                </div>

                <div class="border-t border-stone-100 dark:border-stone-800/80 pt-6 mt-2 transition-colors">
                    <span class="text-[8px] uppercase tracking-[0.3em] font-black text-stone-400 block mb-1">Folio de Acceso</span>
                    <p class="text-sm text-stone-900 dark:text-white font-mono font-bold tracking-widest">#{idOrden.slice(-8).toUpperCase()}</p>
                </div>
            </div>

            <div class="flex flex-col gap-8 w-full max-w-xs mx-auto">
                <a href={urlTicket} target="_blank" class="text-[10px] uppercase tracking-[0.3em] font-black text-stone-900 dark:text-white hover:text-orange-600 dark:hover:text-orange-500 transition-colors flex items-center justify-center gap-2 group border-b border-transparent hover:border-orange-500 pb-1 w-fit mx-auto">
                    <span>Ver ticket completo</span>
                    <span class="group-hover:translate-x-1 transition-transform">→</span>
                </a>

                <a href="/tienda/chocolates" class="w-full bg-stone-900 dark:bg-white text-white dark:text-black py-5 rounded-full text-[10px] font-black uppercase tracking-[0.3em] shadow-xl hover:bg-orange-600 hover:text-white dark:hover:bg-orange-600 transition-all active:scale-95 cursor-pointer">
                    Volver a la Colección
                </a>
            </div>
        </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js"></script>
    <script define:vars={{ urlTicket }}>
        const canvas = document.getElementById('qrcode-canvas');
        QRCode.toCanvas(canvas, urlTicket, {
            width: 220,
            margin: 2,
            color: {
                dark: '#1c1917', // Color Stone-900
                light: '#ffffff'
            }
        });
    </script>
</Layout>