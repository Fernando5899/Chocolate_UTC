---
import Layout from '../../layouts/Layout.astro';

// Obtenemos el número de orden si viene en la URL (ej: /tienda/gracias?orden=clxyz123)
const ordenId = Astro.url.searchParams.get('orden') || 'No. de Folio en tu Perfil';
---

<Layout title="Compra Exitosa | Museo">
    <div class="max-w-4xl mx-auto px-8 py-24 text-center transition-colors duration-500 min-h-[70vh] flex flex-col justify-center">

        <div class="bg-white/60 dark:bg-[#110e0d]/80 backdrop-blur-xl p-12 md:p-20 rounded-[40px] border border-white/50 dark:border-stone-800 shadow-2xl transition-colors duration-500">

            <div class="w-24 h-24 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-500 rounded-full flex items-center justify-center text-5xl mx-auto mb-8 shadow-inner border border-green-200 dark:border-green-800/50">
                ✓
            </div>

            <h1 class="text-5xl font-black italic text-stone-900 dark:text-white mb-6">¡Expedición Confirmada!</h1>

            <p class="text-lg text-stone-600 dark:text-stone-400 mb-8 max-w-xl mx-auto">
                Tu solicitud ha sido registrada en los archivos del museo. Hemos enviado un comprobante a tu correo electrónico institucional.
            </p>

            <div class="bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-6 rounded-2xl inline-block mb-12 shadow-inner">
                <span class="text-xs uppercase tracking-widest text-stone-500 font-bold block mb-1">Folio de Registro</span>
                <span class="text-2xl font-mono text-orange-600 dark:text-orange-500 font-black">#{ordenId.slice(-6).toUpperCase()}</span>
            </div>

            <div class="flex flex-col md:flex-row gap-6 justify-center">
                <a href="/cuenta/perfil" class="bg-stone-900 dark:bg-white text-white dark:text-black px-10 py-5 rounded-full font-bold uppercase text-[10px] tracking-widest hover:bg-orange-600 hover:dark:bg-orange-500 hover:text-white transition-all shadow-xl active:scale-95">
                    Ver mis boletos
                </a>
                <a href="/" class="bg-white dark:bg-[#110e0d] text-stone-900 dark:text-white border border-stone-200 dark:border-stone-800 px-10 py-5 rounded-full font-bold uppercase text-[10px] tracking-widest hover:border-orange-500 transition-all">
                    Volver al Inicio
                </a>
            </div>

        </div>
    </div>
</Layout>