---
import Layout from '../../layouts/Layout.astro';

// Obtenemos el ID de la orden que viene en la URL (?orden=...)
const idOrden = Astro.url.searchParams.get('orden');

if (!idOrden) return Astro.redirect('/tienda/chocolates');

// URL que abrirá el QR (Cámbiala por tu dominio de Vercel cuando despliegues)
const urlTicket = `https://chocolate-utc.vercel.app/ticket/${idOrden}`;
---

<Layout title="¡Gracias por tu compra! | Museo">
    <div class="min-h-screen flex items-center justify-center bg-stone-50 dark:bg-[#0c0a09] px-6 py-20">
        <div class="max-w-md w-full text-center">

            <div class="mb-12">
                <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
                    <span class="text-4xl">✨</span>
                </div>
                <h1 class="text-4xl font-serif italic font-black dark:text-white mb-4">¡Orden Confirmada!</h1>
                <p class="text-stone-500 dark:text-stone-400 text-sm">Tu pedido ha sido registrado. Escanea o guarda este código para tu acceso y comprobante.</p>
            </div>

            <div class="bg-white dark:bg-[#110e0d] p-10 rounded-[50px] shadow-2xl border border-stone-200 dark:border-stone-800 mb-10 transition-colors duration-500">
                <span class="text-[9px] uppercase tracking-[0.3em] font-bold text-stone-400 block mb-8">Pase Digital de Visitante</span>

                <div class="flex justify-center mb-8 bg-white p-4 rounded-3xl inline-block mx-auto">
                    <canvas id="qrcode-canvas"></canvas>
                </div>

                <p class="text-[10px] text-stone-400 uppercase tracking-widest font-bold">ID: {idOrden}</p>
            </div>

            <div class="flex flex-col gap-6">
                <a href={urlTicket} class="text-[10px] uppercase tracking-widest font-bold text-orange-600 dark:text-orange-500 border-b border-orange-500/30 pb-1 mx-auto hover:border-orange-500 transition-all">
                    Ver ticket digital completo
                </a>

                <a href="/tienda/chocolates" class="bg-stone-900 dark:bg-white text-white dark:text-black py-5 rounded-full text-[10px] font-bold uppercase tracking-[0.2em] shadow-xl hover:bg-orange-600 transition-all">
                    Volver a la Tienda
                </a>
            </div>
        </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js"></script>
    <script define:vars={{ urlTicket }}>
        const canvas = document.getElementById('qrcode-canvas');
        QRCode.toCanvas(canvas, urlTicket, {
            width: 220,
            margin: 2,
            color: {
                dark: '#1c1917', // Color Stone-900
                light: '#ffffff'
            }
        });
    </script>
</Layout>