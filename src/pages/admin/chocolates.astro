---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

// Herramientas de Node.js para guardar archivos
import fs from 'node:fs';
import path from 'node:path';

const session = await getSession(Astro.request);
if (!session) {
    return Astro.redirect('/cuenta/login');
}

let mensaje = "";
let tipoMensaje = "";

if (Astro.request.method === 'POST') {
    try {
        const data = await Astro.request.formData();

        const nombre = data.get('nombre')?.toString();
        const descripcion = data.get('descripcion')?.toString();
        const precio = parseFloat(data.get('precio')?.toString() || '0');
        const stock = parseInt(data.get('stock')?.toString() || '0');
        const categoriaId = data.get('categoriaId')?.toString();

        // 1. Extraemos la imagen del formulario
        const imagenFile = data.get('imagen') as File;
        let imagenUrl = null;

        // 2. Si el usuario subió una imagen válida, la procesamos
        if (imagenFile && imagenFile.size > 0) {
            // Convertimos el archivo a un formato que Node.js entienda
            const arrayBuffer = await imagenFile.arrayBuffer();
            const buffer = Buffer.from(arrayBuffer);

            // Creamos un nombre único para que no se sobreescriban fotos con el mismo nombre
            const nombreUnico = `${Date.now()}-${imagenFile.name.replace(/\s+/g, '-')}`;

            // Definimos dónde se va a guardar (en tu carpeta public/uploads)
            const rutaCarpeta = path.join(process.cwd(), 'public', 'uploads');
            const rutaCompleta = path.join(rutaCarpeta, nombreUnico);

            // Si por alguna razón la carpeta 'uploads' no existe, la creamos
            if (!fs.existsSync(rutaCarpeta)) {
                fs.mkdirSync(rutaCarpeta, { recursive: true });
            }

            // ¡Guardamos la foto en el disco duro!
            fs.writeFileSync(rutaCompleta, buffer);

            // Esta es la ruta web que guardaremos en la base de datos
            imagenUrl = `/uploads/${nombreUnico}`;
        }

        if (nombre && categoriaId) {
            await prisma.chocolate.create({
                data: {
                    nombre,
                    descripcion: descripcion || '',
                    precio,
                    stock,
                    categoriaId,
                    imagenUrl // <-- Guardamos la ruta de la foto en la base de datos
                }
            });
            mensaje = "✅ ¡Chocolate guardado con imagen!";
            tipoMensaje = "success";
        }
    } catch (error) {
        console.error("🔥 Error al guardar:", error);
        mensaje = "❌ Hubo un error al intentar guardar el producto.";
        tipoMensaje = "error";
    }
}

const categorias = await prisma.categoria.findMany({ orderBy: { nombre: 'asc' } });
---

<Layout title="Chocolates | Admin">
    <div class="max-w-4xl mx-auto">

        <nav class="flex space-x-4 mb-8 border-b border-stone-200 pb-4">
            <a href="/admin" class="text-stone-500 hover:text-orange-600 font-medium transition-colors">Categorías</a>
            <a href="/admin/chocolates" class="text-orange-600 font-bold border-b-2 border-orange-600 pb-4 -mb-4">Chocolates</a>
        </nav>

        {mensaje && (
                <div class={`p-4 mb-6 rounded-lg font-medium shadow-sm border ${tipoMensaje === 'error' ? 'bg-red-100 text-red-800 border-red-200' : 'bg-green-100 text-green-800 border-green-200'}`}>
                    {mensaje}
                </div>
        )}

        <form method="POST" enctype="multipart/form-data" class="bg-white p-8 rounded-2xl shadow-sm border border-stone-200 space-y-6 mb-12">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-6">
                    <div>
                        <label for="nombre" class="block text-sm font-semibold text-stone-700 mb-2">Nombre del Chocolate</label>
                        <input type="text" name="nombre" id="nombre" required class="w-full px-4 py-3 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500"/>
                    </div>

                    <div>
                        <label for="categoriaId" class="block text-sm font-semibold text-stone-700 mb-2">Categoría</label>
                        <select name="categoriaId" id="categoriaId" required class="w-full px-4 py-3 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500 bg-white">
                            <option value="" disabled selected>Selecciona una categoría...</option>
                            {categorias.map((cat) => (
                                    <option value={cat.id}>{cat.nombre}</option>
                            ))}
                        </select>
                    </div>

                    <div>
                        <label for="imagen" class="block text-sm font-semibold text-stone-700 mb-2">Fotografía (Opcional)</label>
                        <input type="file" name="imagen" id="imagen" accept="image/*" class="w-full px-4 py-2 rounded-xl border border-stone-300 text-sm text-stone-600 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 transition-all"/>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label for="precio" class="block text-sm font-semibold text-stone-700 mb-2">Precio (MXN)</label>
                        <input type="number" step="0.01" min="0" name="precio" id="precio" required class="w-full px-4 py-3 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500"/>
                    </div>

                    <div>
                        <label for="stock" class="block text-sm font-semibold text-stone-700 mb-2">Cantidad en Stock</label>
                        <input type="number" min="0" name="stock" id="stock" required class="w-full px-4 py-3 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500"/>
                    </div>
                </div>
            </div>

            <div>
                <label for="descripcion" class="block text-sm font-semibold text-stone-700 mb-2">Descripción del Producto</label>
                <textarea name="descripcion" id="descripcion" rows="3" class="w-full px-4 py-3 rounded-xl border border-stone-300 outline-none focus:ring-2 focus:ring-orange-500"></textarea>
            </div>

            <button type="submit" class="w-full bg-stone-900 text-white font-bold py-3 px-6 rounded-xl hover:bg-stone-800 transition-colors cursor-pointer">
                Guardar en Inventario
            </button>
        </form>

    </div>
</Layout>