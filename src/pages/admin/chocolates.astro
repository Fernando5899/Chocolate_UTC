---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

// Seguridad
const session = await getSession(Astro.request);
if (session?.user?.email !== 'fernando.jose.reynosa@gmail.com') return Astro.redirect('/');

let mensaje = "";
let tipoMensaje = "";

if (Astro.request.method === 'POST') {
    try {
        const data = await Astro.request.formData();
        const intent = data.get('intent')?.toString();

        if (intent === 'crear') {
            const nombre = data.get('nombre')?.toString() || '';
            const precio = parseFloat(data.get('precio')?.toString() || '0');
            const stock = parseInt(data.get('stock')?.toString() || '0');
            const descripcion = data.get('descripcion')?.toString() || '';
            const categoriaId = data.get('categoriaId')?.toString() || '';

            // 🚀 LÓGICA DE SUBIDA DE IMAGEN (Adaptada para Vercel / Base64)
            const imagen = data.get('imagen') as File;
            let imagenUrl = null;

            if (imagen && imagen.size > 0) {
                // Leemos el archivo y lo convertimos a un Buffer
                const arrayBuffer = await imagen.arrayBuffer();
                const buffer = Buffer.from(arrayBuffer);

                // Lo codificamos a Base64
                const base64String = buffer.toString('base64');
                const mimeType = imagen.type; // ej: image/png o image/jpeg

                // Creamos una Data URL que el navegador puede leer como imagen
                imagenUrl = `data:${mimeType};base64,${base64String}`;
            }

            await prisma.chocolate.create({
                data: { nombre, precio, stock, descripcion, categoriaId, imagenUrl }
            });
            mensaje = "Nueva delicia añadida al catálogo del museo.";
            tipoMensaje = "success";
        }
        else if (intent === 'actualizar_stock') {
            const id = data.get('id')?.toString() || '';
            const nuevoStock = parseInt(data.get('stock')?.toString() || '0');
            await prisma.chocolate.update({ where: { id }, data: { stock: nuevoStock } });
            mensaje = "Inventario sincronizado exitosamente.";
            tipoMensaje = "success";
        }
        else if (intent === 'eliminar') {
            const id = data.get('id')?.toString() || '';
            await prisma.chocolate.delete({ where: { id } });
            mensaje = "Producto retirado de la base de datos.";
            tipoMensaje = "success";
        }
    } catch (error) {
        console.error(error);
        mensaje = "Error al procesar la solicitud en PostgreSQL.";
        tipoMensaje = "error";
    }
}

const categorias = await prisma.categoria.findMany({ orderBy: { nombre: 'asc' } });
const chocolates = await prisma.chocolate.findMany({
    include: { categoria: true },
    orderBy: { createdAt: 'desc' }
});
---

<Layout title="Gestión de Chocolates | Admin">
    <div class="max-w-7xl mx-auto px-8 py-20 w-full transition-colors duration-500">

        <header class="mb-12 border-b border-stone-200 dark:border-stone-800 pb-8 flex justify-between items-end transition-colors duration-500">
            <div>
                <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-sm font-bold block mb-2">Panel de Administración</span>
                <h1 class="text-5xl font-black italic text-stone-900 dark:text-white">Catálogo y Precios</h1>
            </div>
            <a href="/admin/dashboard" class="text-xs uppercase tracking-widest text-stone-500 hover:text-orange-500 font-bold transition-colors">← Volver al Mando</a>
        </header>

        <div class="flex items-center gap-8 border-b border-stone-200 dark:border-stone-800 mb-12 pb-4">
            <a href="/admin/categorias" class="text-stone-500 hover:text-orange-500 uppercase tracking-widest text-xs font-bold transition-colors">Categorías</a>
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-widest text-xs font-bold border-b-2 border-orange-500 pb-4 -mb-[18px]">Chocolates</span>
        </div>

        {mensaje && (
                <div class={`mb-10 p-6 rounded-2xl border text-sm font-bold text-center ${tipoMensaje === 'success' ? 'bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800 text-red-700 dark:text-red-400'}`}>
                    {mensaje}
                </div>
        )}

        <div class="bg-white dark:bg-[#110e0d] p-10 md:p-12 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl mb-16 transition-colors duration-500">
            <h2 class="text-2xl font-bold italic text-stone-900 dark:text-white mb-8 border-b border-stone-100 dark:border-stone-800/80 pb-4">Añadir Nueva Pieza</h2>

            <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <input type="hidden" name="intent" value="crear" />

                <div>
                    <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Nombre del Chocolate</label>
                    <input type="text" name="nombre" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all" />
                </div>

                <div>
                    <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Precio (MXN)</label>
                    <input type="number" name="precio" step="0.01" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all" />
                </div>

                <div>
                    <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Categoría</label>
                    <select name="categoriaId" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white appearance-none transition-all">
                        <option value="" disabled selected>Selecciona una clasificación...</option>
                        {categorias.map(cat => (
                                <option value={cat.id}>{cat.nombre}</option>
                        ))}
                    </select>
                </div>

                <div>
                    <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Stock Inicial</label>
                    <input type="number" name="stock" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all" />
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Fotografía Físca (Opcional)</label>
                    <input type="file" name="imagen" accept="image/*" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-3 rounded-2xl outline-none focus:border-orange-500 text-sm text-stone-900 dark:text-white transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-orange-100 file:text-orange-700 hover:file:bg-orange-200 dark:file:bg-orange-900/50 dark:file:text-orange-300 cursor-pointer" />
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs uppercase tracking-widest text-stone-500 dark:text-stone-400 mb-3 font-bold">Descripción de Sabor y Origen</label>
                    <textarea name="descripcion" rows="3" required class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl outline-none focus:border-orange-500 text-base text-stone-900 dark:text-white transition-all resize-none"></textarea>
                </div>

                <div class="md:col-span-2 pt-4">
                    <button type="submit" class="bg-stone-900 dark:bg-white text-white dark:text-black font-black py-4 px-10 rounded-full hover:bg-orange-600 hover:dark:bg-orange-500 hover:text-white transition-all uppercase text-[10px] tracking-widest shadow-xl active:scale-95 cursor-pointer">
                        Guardar en Inventario
                    </button>
                </div>
            </form>
        </div>

        <h2 class="text-3xl font-black italic text-stone-900 dark:text-white mb-8">Control de Existencias</h2>

        <div class="bg-white dark:bg-[#110e0d] rounded-3xl border border-stone-200 dark:border-stone-800 shadow-xl overflow-hidden transition-colors duration-500">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                    <tr class="bg-stone-50 dark:bg-[#0c0a09] border-b border-stone-200 dark:border-stone-800 text-[10px] uppercase tracking-widest text-stone-500">
                        <th class="p-6 font-bold">Producto</th>
                        <th class="p-6 font-bold">Categoría</th>
                        <th class="p-6 font-bold text-center">Stock Actual</th>
                        <th class="p-6 font-bold text-right">Acciones</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-stone-100 dark:divide-stone-800/50">
                    {chocolates.length === 0 ? (
                            <tr>
                                <td colspan="4" class="p-12 text-center text-stone-500 italic">No hay productos registrados.</td>
                            </tr>
                    ) : (
                        chocolates.map(choco => (
                                <tr class="hover:bg-stone-50 dark:hover:bg-stone-800/20 transition-colors">
                                    <td class="p-6 flex items-center gap-4">
                                        <div class="w-12 h-12 rounded-lg bg-stone-100 dark:bg-stone-900 overflow-hidden border border-stone-200 dark:border-stone-800 flex-shrink-0">
                                            {choco.imagenUrl ? <img src={choco.imagenUrl} class="w-full h-full object-cover grayscale opacity-80" /> : <span class="flex items-center justify-center h-full text-xl opacity-50 grayscale">🍫</span>}
                                        </div>
                                        <div>
                                            <p class="font-bold text-stone-900 dark:text-white font-serif">{choco.nombre}</p>
                                            <p class="text-xs text-stone-500">${choco.precio.toString()}</p>
                                        </div>
                                    </td>
                                    <td class="p-6">
                                        <span class="bg-stone-100 dark:bg-stone-800 text-stone-600 dark:text-stone-400 px-3 py-1 rounded text-[10px] font-bold uppercase tracking-widest">
                                            {choco.categoria?.nombre || 'S/N'}
                                        </span>
                                    </td>
                                    <td class="p-6 text-center">
                                        <form method="POST" class="flex items-center justify-center gap-2">
                                            <input type="hidden" name="intent" value="actualizar_stock" />
                                            <input type="hidden" name="id" value={choco.id} />
                                            <input type="number" name="stock" value={choco.stock} class="w-20 bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-700 p-2 rounded-lg outline-none focus:border-orange-500 text-sm text-center text-stone-900 dark:text-white font-bold" />
                                            <button type="submit" class="p-2 bg-stone-200 dark:bg-stone-800 hover:bg-orange-500 hover:text-white rounded-lg transition-colors cursor-pointer" title="Guardar Stock">💾</button>
                                        </form>
                                    </td>
                                    <td class="p-6 text-right">
                                        <form method="POST" class="inline" onsubmit="return confirm('¿Estás seguro de que deseas descontinuar este producto para siempre?');">
                                            <input type="hidden" name="intent" value="eliminar" />
                                            <input type="hidden" name="id" value={choco.id} />
                                            <button type="submit" class="text-xs font-bold uppercase tracking-widest text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 transition-colors bg-red-50 dark:bg-red-900/20 px-4 py-2 rounded-full border border-red-200 dark:border-red-900/50 cursor-pointer">
                                                Descontinuar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                        ))
                    )}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</Layout>