---
import Layout from '../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../../lib/prisma';

const session = await getSession(Astro.request);
if (session?.user?.email !== 'fernando.jose.reynosa@gmail.com') return Astro.redirect('/');

const salas = await prisma.sala.findMany({ orderBy: { createdAt: 'desc' } });
---

<Layout title="Gestión de Salas | Admin">
    <div class="max-w-7xl mx-auto px-8 py-20 text-stone-900 dark:text-white">
        <header class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-10">
            <h1 class="text-6xl font-black italic mb-4">Salas de Exposición</h1>
            <p class="text-xl text-stone-500">Sube imágenes reales a la nube y gestiona el museo.</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <form id="form-crear-sala" class="lg:col-span-1 space-y-6 bg-white dark:bg-[#110e0d] p-8 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl">
                <h2 class="text-2xl font-bold font-serif mb-6">Inaugurar Sala 🏛️</h2>

                <input type="text" name="nombre" placeholder="Nombre de la Sala" class="w-full bg-stone-100 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl p-4 outline-none" required />

                <div class="space-y-2">
                    <label class="text-xs font-bold text-orange-500 uppercase">Portada Principal</label>
                    <div class="relative aspect-video bg-stone-100 dark:bg-stone-900 rounded-2xl overflow-hidden border-2 border-dashed border-stone-300 dark:border-stone-700">
                        <input type="file" name="imagenPortada" id="input-portada" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-20" required />
                        <img id="preview-portada" class="absolute inset-0 w-full h-full object-cover hidden z-10" />
                        <div id="text-portada" class="absolute inset-0 flex items-center justify-center text-stone-400 text-xs font-bold uppercase">Click para subir</div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-xs font-bold text-stone-500 uppercase">Galería (8 fotos)</label>
                    <div class="grid grid-cols-4 gap-2">
                        {[...Array(8)].map((_, i) => (
                                <div class="relative aspect-square bg-stone-100 dark:bg-stone-900 rounded-lg overflow-hidden border border-dashed border-stone-700">
                                    <input type="file" name={`galeria_${i}`} data-index={i} accept="image/*" class="input-galeria absolute inset-0 opacity-0 cursor-pointer z-20" required />
                                    <img id={`preview-galeria-${i}`} class="absolute inset-0 w-full h-full object-cover hidden z-10" />
                                    <div id={`text-galeria-${i}`} class="absolute inset-0 flex items-center justify-center text-lg">+</div>
                                </div>
                        ))}
                    </div>
                </div>

                <textarea name="descripcion" placeholder="Descripción corta..." class="w-full bg-stone-100 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl p-4 h-24 resize-none" required></textarea>
                <textarea name="historia" placeholder="Historia completa..." class="w-full bg-stone-100 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl p-4 h-32 resize-none"></textarea>

                <button type="submit" id="btn-submit" class="w-full bg-stone-900 dark:bg-white text-white dark:text-stone-900 font-bold py-5 rounded-2xl hover:bg-orange-600 transition-all uppercase tracking-widest text-sm">
                    Guardar en la Nube
                </button>
            </form>

            <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6">
                {salas.map(sala => (
                        <div class="group relative h-64 rounded-[30px] overflow-hidden border border-stone-800 shadow-lg">
                            <img src={sala.imagenUrl} class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform" />
                            <div class="absolute inset-0 p-6 flex flex-col justify-end bg-gradient-to-t from-black">
                                <h3 class="text-2xl font-serif italic text-white">{sala.nombre}</h3>
                                <p class="text-stone-300 text-xs line-clamp-1">{sala.descripcion}</p>
                            </div>
                            <button data-id={sala.id} class="btn-eliminar absolute top-4 right-4 bg-red-600 p-2 rounded-full text-white hover:bg-red-500 transition-colors">🗑️</button>
                        </div>
                ))}
            </div>
        </div>
    </div>

    <script>
        // Previews
        document.getElementById('input-portada')?.addEventListener('change', (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            const preview = document.getElementById('preview-portada') as HTMLImageElement;
            const text = document.getElementById('text-portada');
            if (file) { preview.src = URL.createObjectURL(file); preview.classList.remove('hidden'); text?.classList.add('hidden'); }
        });

        document.querySelectorAll('.input-galeria').forEach(input => {
            input.addEventListener('change', (e) => {
                const target = e.target as HTMLInputElement;
                const idx = target.dataset.index;
                const file = target.files?.[0];
                const preview = document.getElementById(`preview-galeria-${idx}`) as HTMLImageElement;
                const text = document.getElementById(`text-galeria-${idx}`);
                if (file) { preview.src = URL.createObjectURL(file); preview.classList.remove('hidden'); text?.classList.add('hidden'); }
            });
        });

        // Submit
        const form = document.getElementById('form-crear-sala') as HTMLFormElement;
        const btn = document.getElementById('btn-submit') as HTMLButtonElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true; btn.innerText = 'Subiendo a la nube... ⏳';
            try {
                const res = await fetch('/api/salas', { method: 'POST', body: new FormData(form) });
                if (res.ok) window.location.reload();
                else alert('Error al subir');
            } catch { alert('Error de conexión'); }
            finally { btn.disabled = false; btn.innerText = 'Guardar en la Nube'; }
        });

        // Eliminar
        document.querySelectorAll('.btn-eliminar').forEach(b => {
            b.addEventListener('click', async () => {
                if (!confirm('¿Borrar sala y fotos de la nube?')) return;
                const id = (b as HTMLElement).dataset.id;
                await fetch('/api/salas', { method: 'DELETE', body: JSON.stringify({ id }) });
                window.location.reload();
            });
        });
    </script>
</Layout>