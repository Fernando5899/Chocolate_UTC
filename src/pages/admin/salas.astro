---
import Layout from '../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../../lib/prisma';

const session = await getSession(Astro.request);
if (session?.user?.email !== 'fernando.jose.reynosa@gmail.com') return Astro.redirect('/');

const salas = await prisma.sala.findMany({ orderBy: { createdAt: 'desc' } });
---

<Layout title="Gestión de Salas | Admin">
    <div class="max-w-7xl mx-auto px-8 py-20 text-stone-900 dark:text-white">
        <header class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-10">
            <h1 class="text-6xl font-black italic mb-4 text-center lg:text-left">Salas de Exposición</h1>
            <p class="text-xl text-stone-500 text-center lg:text-left">Sube imágenes reales a la nube y gestiona el museo.</p>
        </header>

        <div class="flex flex-col lg:flex-row gap-16">

            <aside class="w-full lg:w-1/3">
                <form id="form-crear-sala" class="sticky top-10 space-y-6 bg-white dark:bg-[#110e0d] p-8 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl">
                    <h2 class="text-2xl font-bold font-serif mb-6">Inaugurar Sala 🏛️</h2>

                    <input type="text" name="nombre" placeholder="Nombre de la Sala" class="w-full bg-stone-100 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl p-4 outline-none focus:ring-2 focus:ring-orange-500 transition-all" required />

                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-orange-500 uppercase tracking-widest">Portada Principal</label>
                        <div class="relative aspect-video bg-stone-100 dark:bg-stone-900 rounded-2xl overflow-hidden border-2 border-dashed border-stone-300 dark:border-stone-700 hover:border-orange-500 transition-colors cursor-pointer">
                            <input type="file" name="imagenPortada" id="input-portada" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-20" required />
                            <img id="preview-portada" alt="Previsualización portada" class="absolute inset-0 w-full h-full object-cover hidden z-10" />
                            <div id="text-portada" class="absolute inset-0 flex items-center justify-center text-stone-400 text-[10px] font-bold uppercase tracking-tighter">Click para subir</div>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-stone-500 uppercase tracking-widest">Galería (8 fotos)</label>
                        <div class="grid grid-cols-4 gap-2">
                            {[...Array(8)].map((_, i) => (
                                    <div class="relative aspect-square bg-stone-100 dark:bg-stone-900 rounded-lg overflow-hidden border border-dashed border-stone-700 hover:border-orange-500 transition-colors">
                                        <input type="file" name={`galeria_${i}`} data-index={i} accept="image/*" class="input-galeria absolute inset-0 opacity-0 cursor-pointer z-20" required />
                                        <img id={`preview-galeria-${i}`} alt={`Previsualización ${i}`} class="absolute inset-0 w-full h-full object-cover hidden z-10" />
                                        <div id={`text-galeria-${i}`} class="absolute inset-0 flex items-center justify-center text-lg">+</div>
                                    </div>
                            ))}
                        </div>
                    </div>

                    <textarea name="descripcion" placeholder="Descripción corta..." class="w-full bg-stone-100 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl p-4 h-24 resize-none outline-none focus:ring-2 focus:ring-orange-500 transition-all" required></textarea>
                    <textarea name="historia" placeholder="Historia completa..." class="w-full bg-stone-100 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl p-4 h-32 resize-none outline-none focus:ring-2 focus:ring-orange-500 transition-all"></textarea>

                    <button type="submit" id="btn-submit" class="w-full bg-stone-900 dark:bg-white text-white dark:text-stone-900 font-bold py-5 rounded-2xl hover:bg-orange-600 dark:hover:bg-orange-500 hover:text-white transition-all uppercase tracking-widest text-xs shadow-lg active:scale-95">
                        Guardar en la Nube
                    </button>
                </form>
            </aside>

            <section class="flex-grow">
                <h2 class="text-2xl font-bold font-serif mb-8 text-center lg:text-left">Salas Activas</h2>

                {salas.length === 0 ? (
                        <div class="text-center p-20 bg-stone-100 dark:bg-stone-900/50 rounded-[40px] border-2 border-dashed border-stone-200 dark:border-stone-800">
                            <p class="text-stone-500 italic">No hay salas inauguradas aún.</p>
                        </div>
                ) : (
                    /* El truco: flex-wrap + justify-center hace que todo se alinee al medio si hay pocos elementos */
                        <div class="flex flex-wrap justify-center lg:justify-start gap-8">
                            {salas.map(sala => (
                                    <div class="relative w-full sm:w-[calc(50%-1rem)] xl:w-[calc(33.33%-1.5rem)] max-w-md h-80 rounded-[40px] overflow-hidden border border-stone-200 dark:border-stone-800 shadow-xl group transition-all hover:-translate-y-2">
                                        <img src={sala.imagenUrl} alt={sala.nombre} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:scale-110 transition-transform duration-700" />
                                        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent p-8 flex flex-col justify-end">
                                            <h3 class="text-3xl font-serif italic text-white mb-2">{sala.nombre}</h3>
                                            <p class="text-stone-300 text-xs line-clamp-2 mb-4">{sala.descripcion}</p>

                                            <div class="flex justify-between items-center">
                                                <a href={`/salas/${sala.id}`} class="text-[10px] font-bold text-white uppercase tracking-widest border-b border-orange-500 pb-1">Ver Sala</a>
                                                <button data-id={sala.id} class="btn-eliminar bg-red-600/90 p-3 rounded-full text-white hover:bg-red-500 transition-colors shadow-lg" title="Borrar Sala">
                                                    🗑️
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                            ))}
                        </div>
                )}
            </section>
        </div>
    </div>

    <script>
        // Lógica de Previsualización
        document.getElementById('input-portada')?.addEventListener('change', (e) => {
            const file = (e.target as HTMLInputElement).files?.[0];
            const preview = document.getElementById('preview-portada') as HTMLImageElement;
            const text = document.getElementById('text-portada');
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.remove('hidden');
                text?.classList.add('hidden');
            }
        });

        document.querySelectorAll('.input-galeria').forEach(input => {
            input.addEventListener('change', (e) => {
                const target = e.target as HTMLInputElement;
                const idx = target.dataset.index;
                const file = target.files?.[0];
                const preview = document.getElementById(`preview-galeria-${idx}`) as HTMLImageElement;
                const text = document.getElementById(`text-galeria-${idx}`);
                if (file) {
                    preview.src = URL.createObjectURL(file);
                    preview.classList.remove('hidden');
                    text?.classList.add('hidden');
                }
            });
        });

        // Lógica de Envío
        const form = document.getElementById('form-crear-sala') as HTMLFormElement;
        const btn = document.getElementById('btn-submit') as HTMLButtonElement;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btn.innerText = 'Subiendo a Cloudinary... ⏳';

            try {
                const res = await fetch('/api/salas', { method: 'POST', body: new FormData(form) });
                if (res.ok) window.location.reload();
                else {
                    const err = await res.json();
                    alert('Error: ' + err.error);
                }
            } catch { alert('Error de conexión'); }
            finally {
                btn.disabled = false;
                btn.innerText = 'Guardar en la Nube';
            }
        });

        // Lógica de Eliminación
        document.querySelectorAll('.btn-eliminar').forEach(b => {
            b.addEventListener('click', async () => {
                if (!confirm('¿Estás seguro? Se borrarán las fotos de la nube y el registro.')) return;
                const id = (b as HTMLElement).dataset.id;
                try {
                    const res = await fetch('/api/salas', {
                        method: 'DELETE',
                        body: JSON.stringify({ id }),
                        headers: { 'Content-Type': 'application/json' }
                    });
                    if (res.ok) window.location.reload();
                } catch { alert("Error al eliminar"); }
            });
        });
    </script>
</Layout>