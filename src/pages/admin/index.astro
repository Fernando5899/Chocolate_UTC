---
// 1. Importamos al guardia de seguridad de auth-astro
import { getSession } from 'auth-astro/server';
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';

// 2. Le preguntamos al guardia si el visitante tiene gafete
const session = await getSession(Astro.request);

// 3. Si NO hay sesión, lo pateamos a la ruta de login
if (!session) {
    return Astro.redirect('/cuenta/login');
}

let mensaje = "";

// Lógica blindada para manejar el formulario
if (Astro.request.method === 'POST') {
    try {
        // 1. Verificamos la etiqueta de seguridad antes de abrir el paquete
        const contentType = Astro.request.headers.get('Content-Type') || '';

        if (contentType.includes('multipart/form-data') || contentType.includes('form-urlencoded')) {
            // 2. Si es seguro, extraemos los datos
            const data = await Astro.request.formData();
            const nombre = data.get('nombre')?.toString();
            const descripcion = data.get('descripcion')?.toString();

            if (nombre) {
                await prisma.categoria.create({
                    data: { nombre, descripcion }
                });
                mensaje = "✅ Categoría guardada con éxito";
            }
        } else {
            console.warn("⚠️ Petición ignorada por formato extraño:", contentType);
        }
    } catch (error) {
        console.error("🔥 ERROR EN LA BASE DE DATOS:", error);
        // Si falla aquí, es casi seguro que la categoría ya existe en PostgreSQL
        mensaje = "❌ Error: Ese nombre de categoría ya existe.";
    }
}
---

<Layout title="Admin | Museo de Chocolate">
    <div class="max-w-2xl mx-auto">
        <header class="mb-8">
            <h1 class="text-3xl font-bold text-stone-800">Panel de Administración</h1>
            <p class="text-stone-600">Gestiona las categorías de tu museo</p>
        </header>

        {mensaje && (
                <div class={`p-4 mb-6 rounded-lg font-medium shadow-sm ${mensaje.includes('✅') ? 'bg-green-100 text-green-800 border border-green-200' : 'bg-red-100 text-red-800 border border-red-200'}`}>
                    {mensaje}
                </div>
        )}

        <form method="POST" enctype="multipart/form-data" class="bg-white p-8 rounded-2xl shadow-sm border border-stone-200 space-y-6">
            <div>
                <label for="nombre" class="block text-sm font-semibold text-stone-700 mb-2">Nombre de la Categoría</label>
                <input
                        type="text"
                        name="nombre"
                        id="nombre"
                        required
                        placeholder="Ej. Chocolates Blancos"
                        class="w-full px-4 py-3 rounded-xl border border-stone-300 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all"
                />
            </div>

            <div>
                <label for="descripcion" class="block text-sm font-semibold text-stone-700 mb-2">Descripción (Opcional)</label>
                <textarea
                        name="descripcion"
                        id="descripcion"
                        rows="3"
                        placeholder="Describe qué hace especial a esta categoría..."
                        class="w-full px-4 py-3 rounded-xl border border-stone-300 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all"
                ></textarea>
            </div>

            <button
                    type="submit"
                    class="w-full bg-stone-900 text-white font-bold py-3 px-6 rounded-xl hover:bg-stone-800 transform active:scale-95 transition-all shadow-lg cursor-pointer"
            >
                Guardar Categoría
            </button>
        </form>

        <div class="mt-8 text-center">
            <a href="/" class="text-stone-500 hover:text-orange-600 font-medium transition-colors">← Volver al inicio</a>
        </div>
    </div>
</Layout>