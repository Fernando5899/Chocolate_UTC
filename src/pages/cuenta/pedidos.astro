---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/cuenta/login');

// 1. Buscamos al usuario y sus órdenes vinculadas
const usuario = await prisma.user.findUnique({
    where: { email: session.user?.email || '' },
    include: {
        ordenes: {
            include: {
                detalles: {
                    include: { chocolate: true }
                }
            },
            orderBy: { fecha: 'desc' }
        }
    }
}) as any;

const ordenes = usuario?.ordenes || [];
---

<Layout title="Historial de Expediciones | Museo de Chocolate">
    <div class="max-w-7xl mx-auto px-8 py-24 md:py-32 transition-colors duration-500">
        
        <header class="mb-20 border-b border-stone-200 dark:border-stone-800 pb-12">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.5em] text-[10px] font-black block mb-4">Mi Perfil</span>
            <h1 class="text-6xl md:text-8xl font-serif italic font-black text-stone-900 dark:text-white tracking-tight">Expediciones</h1>
        </header>

        {ordenes.length === 0 ? (
            <div class="text-center py-32 px-8 bg-white dark:bg-[#110e0d]/50 backdrop-blur-md rounded-[50px] border border-stone-200 dark:border-stone-800 border-dashed transition-all">
                <span class="text-7xl mb-8 block opacity-30 grayscale">📜</span>
                <h2 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-4">Sin registros previos</h2>
                <p class="text-stone-500 dark:text-stone-400 font-serif italic text-lg max-w-md mx-auto mb-10">Aún no has iniciado ninguna expedición en nuestra boutique. Tu historial comenzará con tu primera adquisición.</p>
                <a href="/tienda/chocolates" class="bg-stone-900 dark:bg-white text-white dark:text-black font-black py-5 px-12 rounded-full uppercase text-[10px] tracking-[0.3em] hover:bg-orange-600 hover:text-white dark:hover:bg-orange-600 transition-all shadow-xl active:scale-95 inline-block">
                    Visitar la Boutique
                </a>
            </div>
        ) : (
            <div class="space-y-10">
                {ordenes.map((orden: any) => (
                    <div class="bg-white dark:bg-[#110e0d] p-10 md:p-14 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl flex flex-col lg:flex-row justify-between items-start lg:items-center gap-10 group hover:border-orange-500/50 transition-all duration-500">
                        
                        <div class="flex-grow space-y-6">
                            <div class="flex flex-wrap items-center gap-4">
                                <span class="bg-stone-100 dark:bg-[#0c0a09] px-4 py-2 rounded-full text-[10px] font-mono font-black text-stone-500 dark:text-stone-400 border border-stone-200 dark:border-stone-800 uppercase tracking-wider">
                                    Folio #{orden.id.slice(-8).toUpperCase()}
                                </span>
                                <span class="text-xs text-stone-400 font-black uppercase tracking-widest flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
                                    {new Date(orden.fecha).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' })}
                                </span>
                            </div>

                            <div>
                                <h3 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-3">
                                    Expedición de {orden.detalles.length} Artículo(s)
                                </h3>
                                <p class="text-sm font-serif italic text-stone-500 dark:text-stone-400 flex items-center gap-2">
                                    <span class="opacity-50">📍</span> Destino: <span class="text-stone-700 dark:text-stone-300 not-italic font-sans font-bold ml-1 uppercase text-[11px] tracking-wide">{orden.direccion}, {orden.estadoEnvio}</span>
                                </p>
                            </div>
                        </div>

                        <div class="w-full lg:w-auto flex flex-row lg:flex-col items-center lg:items-end justify-between lg:justify-center gap-6 pt-8 lg:pt-0 border-t lg:border-t-0 lg:border-l border-stone-100 dark:border-stone-800 lg:pl-12 transition-colors">
                            <div class="text-left lg:text-right">
                                <span class="text-[9px] font-black text-stone-400 uppercase tracking-[0.3em] block mb-1">Aporte Total</span>
                                <span class="text-4xl font-black text-stone-900 dark:text-white font-mono tracking-tighter">${orden.total.toFixed(2)}</span>
                            </div>
                            
                            <a href={`/ticket/${orden.id}`} class="bg-stone-900 dark:bg-white text-white dark:text-black px-10 py-4 rounded-full text-[10px] font-black uppercase tracking-[0.2em] hover:bg-orange-600 hover:text-white dark:hover:bg-orange-600 transition-all shadow-lg active:scale-95 whitespace-nowrap">
                                Ver Recibo 📄
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        )}

    </div>
</Layout>