---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/cuenta/login');

const usuario = await prisma.user.findUnique({
    where: { email: session.user?.email || '' },
    include: {
        ordenes: {
            include: { detalles: true },
            orderBy: { fecha: 'desc' }
        }
    }
}) as any;

const todasLasOrdenes = usuario?.ordenes || [];
---

<Layout title="Mis Boletos | Museo de Chocolate">
    <div class="max-w-7xl mx-auto px-8 py-24 md:py-32 transition-colors duration-500">
        
        <header class="mb-20 border-b border-stone-200 dark:border-stone-800 pb-12">
            <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.5em] text-[10px] font-black block mb-4">Taquilla Personal</span>
            <h1 class="text-6xl md:text-8xl font-serif italic font-black text-stone-900 dark:text-white tracking-tight">Mis Accesos</h1>
        </header>

        {todasLasOrdenes.length === 0 ? (
            <div class="text-center py-32 px-8 bg-white dark:bg-[#110e0d]/50 backdrop-blur-md rounded-[50px] border border-stone-200 dark:border-stone-800 border-dashed transition-all">
                <span class="text-7xl mb-8 block opacity-30 grayscale">🎫</span>
                <h2 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-4">No hay boletos reservados</h2>
                <p class="text-stone-500 dark:text-stone-400 font-serif italic text-lg max-w-md mx-auto mb-10">Tu colección personal de accesos está vacía. Es momento de planear tu próxima visita.</p>
                <a href="/visita/boletos" class="bg-stone-900 dark:bg-white text-white dark:text-black font-black py-5 px-12 rounded-full uppercase text-[10px] tracking-[0.3em] hover:bg-orange-600 hover:text-white dark:hover:bg-orange-600 transition-all shadow-xl active:scale-95 inline-block">
                    Adquirir Entradas
                </a>
            </div>
        ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                {todasLasOrdenes.map((orden: any) => (
                    <a href={`/ticket/${orden.id}`} class="block relative group transition-all duration-700 hover:-translate-y-3">
                        
                        <div class="bg-white dark:bg-[#110e0d] p-10 rounded-[40px] border border-stone-200 dark:border-stone-800 shadow-xl overflow-hidden relative transition-all group-hover:border-orange-500/50">
                            
                            <div class="absolute top-1/2 -left-5 w-10 h-10 bg-stone-50 dark:bg-[#0c0a09] rounded-full border border-stone-200 dark:border-stone-800 -translate-y-1/2 transition-colors duration-500"></div>
                            <div class="absolute top-1/2 -right-5 w-10 h-10 bg-stone-50 dark:bg-[#0c0a09] rounded-full border border-stone-200 dark:border-stone-800 -translate-y-1/2 transition-colors duration-500"></div>

                            <div class="flex justify-between items-start mb-8 border-b border-dashed border-stone-200 dark:border-stone-800 pb-6">
                                <div>
                                    <h3 class="text-2xl font-serif font-black italic text-stone-900 dark:text-white leading-none mb-2">Entrada Real</h3>
                                    <span class="text-[9px] uppercase font-black text-orange-600 dark:text-orange-500 tracking-[0.3em]">Pase de Visitante</span>
                                </div>
                                <span class="text-[10px] font-mono font-bold text-stone-400 bg-stone-50 dark:bg-[#0c0a09] px-3 py-1 rounded-md border border-stone-200 dark:border-stone-800">
                                    #{orden.id.slice(-6).toUpperCase()}
                                </span>
                            </div>

                            <div class="space-y-6">
                                <div class="flex justify-between items-end">
                                    <div>
                                        <span class="text-[9px] uppercase font-black text-stone-400 block tracking-[0.2em] mb-1">Emisión</span>
                                        <p class="text-sm font-bold text-stone-900 dark:text-stone-200 font-mono">
                                            {new Date(orden.fecha).toLocaleDateString('es-MX', { day: '2-digit', month: 'long' })}
                                        </p>
                                    </div>
                                    <div class="text-right">
                                        <span class="text-[9px] uppercase font-black text-stone-400 block tracking-[0.2em] mb-1">Estatus</span>
                                        <span class="text-[9px] bg-green-500/10 text-green-600 dark:text-green-400 px-3 py-1.5 rounded-full font-black uppercase tracking-widest border border-green-500/20">
                                            Válido
                                        </span>
                                    </div>
                                </div>

                                <div class="bg-white p-5 rounded-3xl flex justify-center border border-stone-100 shadow-inner group-hover:border-orange-500/30 transition-all duration-700">
                                    <img 
                                        src={`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${orden.id}&color=1c1917`} 
                                        class="w-24 h-24 opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" 
                                        alt="Código de Acceso" 
                                    />
                                </div>

                                <div class="text-center pt-2">
                                    <span class="text-[9px] font-black uppercase tracking-[0.4em] text-stone-400 group-hover:text-orange-500 transition-colors">
                                        Pulsa para ampliar
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        )}

    </div>
</Layout>