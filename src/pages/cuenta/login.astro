---
import Layout from '../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
// Si ya está logueado, lo mandamos a su perfil
if (session) return Astro.redirect('/cuenta/perfil');
---

<Layout title="Acceso al Museo | Museo de Chocolate">
    <div class="min-h-[80vh] flex items-center justify-center py-20 px-6">

        <div class="w-full max-w-md bg-white/70 dark:bg-[#110e0d]/80 backdrop-blur-2xl p-10 md:p-16 rounded-[50px] border border-white dark:border-stone-800 shadow-2xl text-center transition-all duration-500">

            <span class="text-6xl mb-10 block drop-shadow-sm opacity-90">🎫</span>
            
            <header class="mb-12">
                <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.5em] text-[10px] font-black mb-4 block">
                    Autenticación
                </span>
                <h1 class="text-5xl font-serif italic font-black text-stone-900 dark:text-white leading-tight">
                    Acceso al Museo
                </h1>
            </header>

            <p class="text-stone-500 dark:text-stone-400 text-base font-serif italic mb-12 leading-relaxed">
                "Inicia sesión para gestionar tus boletos, guardar tu historial de expediciones y acceder a la tienda exclusiva."
            </p>

            <button
                id="login-google"
                class="w-full bg-stone-900 dark:bg-white text-white dark:text-black font-black py-5 px-8 rounded-full hover:bg-orange-600 hover:dark:bg-orange-600 hover:text-white transition-all shadow-xl flex items-center justify-center gap-4 cursor-pointer uppercase text-[10px] tracking-[0.2em] active:scale-95 border-none group"
            >
                <svg class="w-5 h-5 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span>Ingresar con Google</span>
            </button>

            <div class="mt-12 pt-8 border-t border-stone-100 dark:border-stone-800/50">
                <a href="/" class="inline-flex items-center gap-2 text-[9px] font-black text-stone-400 hover:text-orange-500 uppercase tracking-[0.3em] transition-all group">
                    <span class="group-hover:-translate-x-1 transition-transform">←</span>
                    Volver a la Galería
                </a>
            </div>
        </div>

    </div>
</Layout>

<script>
    import { signIn } from "auth-astro/client";

    const btn = document.getElementById('login-google');

    if (btn) {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            // Deshabilitar botón para evitar múltiples clics
            (btn as HTMLButtonElement).disabled = true;
            btn.innerHTML = "CONECTANDO...";
            
            await signIn("google");
        });
    }
</script>