---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/cuenta/login');

let mensaje = "";
let tipoMensaje = "";

const emailUsuario = session.user?.email || '';
const nombreGoogle = session.user?.name || 'Visitante Distinguido';
const avatarGoogle = session.user?.image || '';

// LÓGICA ROBUSTA: UPSERT (Crear o Actualizar)
if (Astro.request.method === 'POST') {
    try {
        const data = await Astro.request.formData();

        const telefono = data.get('telefono')?.toString().trim();
        const direccion = data.get('direccion')?.toString().trim();
        const estado = data.get('estado')?.toString();
        const cp = data.get('cp')?.toString().trim();

        await prisma.user.upsert({
            where: { email: emailUsuario },
            update: {
                telefono, direccion, estado, codigoPostal: cp, name: nombreGoogle, image: avatarGoogle
            },
            create: {
                email: emailUsuario,
                name: nombreGoogle,
                image: avatarGoogle,
                telefono,
                direccion,
                estado,
                codigoPostal: cp
            }
        });

        mensaje = "Tus datos de envío han sido actualizados con éxito.";
        tipoMensaje = "success";
    } catch (error) {
        mensaje = "Error de sincronización. Verifica que los datos sean correctos.";
        tipoMensaje = "error";
    }
}

// Consultamos usuario e incluimos sus órdenes
const usuario = await prisma.user.findUnique({
    where: { email: emailUsuario },
    include: {
        ordenes: {
            orderBy: { fecha: 'desc' },
            include: { detalles: { include: { chocolate: true } } }
        }
    }
});

const ordenes = usuario?.ordenes || [];
---

<Layout title="Mi Credencial | Museo">
    <div class="max-w-5xl mx-auto px-8 py-20 w-full">

        <header class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-10 flex flex-col md:flex-row items-center md:items-end gap-8 text-center md:text-left transition-colors duration-500">
            {avatarGoogle ? (
                    <img src={avatarGoogle} alt="Avatar de Google" referrerpolicy="no-referrer" class="w-24 h-24 rounded-full border-4 border-stone-200 dark:border-stone-800 shadow-xl object-cover" />
            ) : (
                    <div class="w-24 h-24 rounded-full bg-stone-200 dark:bg-stone-800 flex items-center justify-center text-3xl">👤</div>
            )}

            <div>
                <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.4em] text-sm font-bold block mb-2">Credencial Digital</span>
                <h1 class="text-5xl font-black italic text-stone-900 dark:text-white">{nombreGoogle}</h1>
                <p class="text-stone-500 dark:text-stone-400 font-mono mt-2">{emailUsuario}</p>
            </div>
        </header>

        {mensaje && (
                <div class={`mb-10 p-6 rounded-2xl border text-base font-bold text-center ${tipoMensaje === 'success' ? 'bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800 text-red-700 dark:text-red-400'}`}>
                    {mensaje}
                </div>
        )}

        <section class="mb-32">
            <form method="POST" class="bg-white/60 dark:bg-[#110e0d]/60 backdrop-blur-xl p-10 md:p-12 rounded-[40px] border border-white/50 dark:border-stone-800 shadow-2xl transition-colors duration-500">

                <div class="mb-8 border-b border-stone-200 dark:border-stone-800 pb-6 transition-colors duration-500">
                    <h2 class="text-2xl font-bold italic text-stone-800 dark:text-stone-300 mb-2">Datos de Entrega y Contacto</h2>
                    <p class="text-sm text-stone-500">Proporciona la dirección donde recibirás tus pedidos. Tu identidad está validada por Google.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label class="block text-xs uppercase tracking-[0.2em] text-stone-500 dark:text-stone-400 mb-3 font-bold">Teléfono de Contacto</label>
                        <input type="tel" name="telefono" value={usuario?.telefono} maxlength="15" required placeholder="Ej: 55 1234 5678" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl focus:border-orange-500 outline-none transition-all text-base text-stone-900 dark:text-white" />
                    </div>

                    <div>
                        <label class="block text-xs uppercase tracking-[0.2em] text-stone-500 dark:text-stone-400 mb-3 font-bold">Código Postal</label>
                        <input type="text" name="cp" maxlength="5" value={usuario?.codigoPostal} required placeholder="Ej: 56366" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl focus:border-orange-500 outline-none transition-all text-base text-stone-900 dark:text-white" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-xs uppercase tracking-[0.2em] text-stone-500 dark:text-stone-400 mb-3 font-bold">Dirección Completa (Calle, Número, Colonia)</label>
                        <input type="text" name="direccion" value={usuario?.direccion} required placeholder="Ingresa tu dirección de envío..." class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl focus:border-orange-500 outline-none transition-all text-base text-stone-900 dark:text-white" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-xs uppercase tracking-[0.2em] text-stone-500 dark:text-stone-400 mb-3 font-bold">Estado / Entidad</label>
                        <select name="estado" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-4 rounded-2xl focus:border-orange-500 outline-none transition-all text-base text-stone-900 dark:text-white appearance-none">
                            <option value="CDMX" selected={usuario?.estado === 'CDMX'}>Ciudad de México</option>
                            <option value="Edomex" selected={usuario?.estado === 'Edomex'}>Estado de México</option>
                        </select>
                    </div>

                    <div class="md:col-span-2 pt-6">
                        <button type="submit" class="w-full md:w-auto bg-stone-900 dark:bg-white text-white dark:text-black font-black py-5 px-12 rounded-full hover:bg-orange-600 hover:dark:bg-orange-500 hover:text-white transition-all uppercase text-sm tracking-[0.3em] shadow-xl active:scale-95 cursor-pointer">
                            Guardar Dirección
                        </button>
                    </div>
                </div>
            </form>
        </section>

        <section>
            <h2 class="text-4xl font-bold italic mb-10 border-b border-stone-200 dark:border-stone-900 pb-6 text-stone-900 dark:text-white transition-colors duration-500">Bitácora de Pedidos</h2>

            {ordenes.length === 0 ? (
                    <div class="p-16 text-center border border-dashed border-stone-300 dark:border-stone-800 rounded-[40px] text-stone-500 dark:text-stone-400 text-lg transition-colors duration-500">
                        Aún no se registran expediciones en tu cuenta.
                    </div>
            ) : (
                    <div class="space-y-8">
                        {ordenes.map(orden => {
                            // Lógica para detectar si compró boletos
                            const tieneBoletos = orden.detalles.length === 0 && orden.total > 0;

                            return (
                                    <div class="bg-white dark:bg-[#110e0d] border border-stone-200 dark:border-stone-800 p-8 rounded-3xl flex flex-col md:flex-row justify-between gap-8 hover:border-orange-500 transition-colors shadow-lg duration-500">
                                        <div>
                                            <div class="flex items-center gap-4 mb-4">
                                                <span class="text-xs bg-stone-100 dark:bg-stone-800 text-stone-600 dark:text-stone-400 px-3 py-1 rounded-md uppercase tracking-widest font-mono border border-stone-200 dark:border-stone-700">#{orden.id.slice(-6).toUpperCase()}</span>
                                                <span class="text-sm text-stone-500">{new Date(orden.fecha).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
                                            </div>
                                            <div class="space-y-2">
                                                {orden.detalles.map(det => (
                                                        <p class="text-base text-stone-700 dark:text-stone-300 italic font-serif">• {det.cantidad}x {det.chocolate?.nombre}</p>
                                                ))}
                                                {/* Si tiene boletos, mostramos esta etiqueta naranja */}
                                                {tieneBoletos && <p class="text-orange-500 dark:text-orange-400 not-italic font-bold text-xs uppercase mt-2">🎫 Accesos Digitales Incluidos</p>}
                                            </div>
                                        </div>
                                        <div class="md:text-right flex flex-col justify-center border-t md:border-t-0 md:border-l border-stone-100 dark:border-stone-800 pt-6 md:pt-0 md:pl-8 transition-colors duration-500">
                                            <span class="text-xs text-stone-500 uppercase tracking-widest mb-2 font-bold">Total Pagado</span>
                                            <span class="text-4xl font-black text-stone-900 dark:text-white transition-colors duration-500">${orden.total.toFixed(2)}</span>
                                        </div>
                                    </div>
                            )
                        })}
                    </div>
            )}
        </section>
    </div>
</Layout>