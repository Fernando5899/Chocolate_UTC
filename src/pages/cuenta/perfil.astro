---
import Layout from '../../layouts/Layout.astro';
import prisma from '../../lib/prisma';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/cuenta/login');

let mensaje = "";
let tipoMensaje = "";

const emailUsuario = session.user?.email || '';
const nombreGoogle = session.user?.name || 'Visitante Distinguido';
const avatarGoogle = session.user?.image || '';

// LÓGICA DE ACTUALIZACIÓN (POST)
if (Astro.request.method === 'POST') {
    try {
        const data = await Astro.request.formData();
        const telefono = data.get('telefono')?.toString().trim();
        const direccion = data.get('direccion')?.toString().trim();
        const estado = data.get('estado')?.toString();
        const cp = data.get('cp')?.toString().trim();

        await prisma.user.upsert({
            where: { email: emailUsuario },
            update: { telefono, direccion, estado, codigoPostal: cp, name: nombreGoogle, image: avatarGoogle },
            create: { email: emailUsuario, name: nombreGoogle, image: avatarGoogle, telefono, direccion, estado, codigoPostal: cp }
        });

        mensaje = "Sincronización exitosa con la base de datos.";
        tipoMensaje = "success";
    } catch (error) {
        mensaje = "Error de enlace. Verifica la integridad de los datos.";
        tipoMensaje = "error";
    }
}

// CONSULTA DE DATOS
const usuario = await prisma.user.findUnique({
    where: { email: emailUsuario },
    include: {
        ordenes: {
            orderBy: { fecha: 'desc' },
            include: { detalles: { include: { chocolate: true } } }
        }
    }
});

const ordenes = usuario?.ordenes || [];
---

<Layout title="Mi Credencial | Museo de Chocolate">
    <div class="max-w-7xl mx-auto px-8 py-24 md:py-32 transition-colors duration-500">

        <header class="mb-20 border-b border-stone-200 dark:border-stone-800 pb-12 flex flex-col md:flex-row items-center md:items-end gap-10 text-center md:text-left">
            <div class="relative group">
                {avatarGoogle ? (
                    <img src={avatarGoogle} alt="Avatar" referrerpolicy="no-referrer" class="w-32 h-32 rounded-full border-4 border-white dark:border-stone-800 shadow-2xl object-cover transition-transform duration-500 group-hover:scale-105" />
                ) : (
                    <div class="w-32 h-32 rounded-full bg-stone-200 dark:bg-stone-800 flex items-center justify-center text-4xl shadow-2xl">👤</div>
                )}
                <div class="absolute -bottom-2 -right-2 bg-orange-600 text-white p-2 rounded-full shadow-lg border-4 border-stone-50 dark:border-[#0c0a09]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                </div>
            </div>

            <div class="flex-grow">
                <span class="text-orange-600 dark:text-orange-500 uppercase tracking-[0.5em] text-[10px] font-black block mb-4">Registro Institucional</span>
                <h1 class="text-5xl md:text-7xl font-serif italic font-black text-stone-900 dark:text-white leading-none tracking-tight">{nombreGoogle}</h1>
                <p class="text-stone-500 dark:text-stone-400 font-mono text-sm mt-4 opacity-70">{emailUsuario}</p>
            </div>
        </header>

        {mensaje && (
            <div class={`mb-12 p-6 rounded-3xl border-2 flex items-center justify-center gap-4 text-sm font-black uppercase tracking-widest animate-in fade-in slide-in-from-top-4 duration-500 ${tipoMensaje === 'success' ? 'bg-green-500/10 border-green-500/20 text-green-600 dark:text-green-400' : 'bg-red-500/10 border-red-500/20 text-red-600 dark:text-red-400'}`}>
                <span>{tipoMensaje === 'success' ? '✓' : '⚠️'}</span>
                {mensaje}
            </div>
        )}

        <section class="mb-32">
            <form method="POST" class="bg-white/70 dark:bg-[#110e0d]/70 backdrop-blur-2xl p-10 md:p-16 rounded-[50px] border border-white dark:border-stone-800 shadow-2xl transition-all duration-500">

                <div class="mb-12 border-b border-stone-200 dark:border-stone-800 pb-8">
                    <h2 class="text-3xl font-serif italic font-black text-stone-900 dark:text-white mb-3">Datos de Entrega y Contacto</h2>
                    <p class="text-sm text-stone-500 dark:text-stone-400 font-serif italic">"Información sensible utilizada exclusivamente para la logística de tus expediciones."</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <div>
                        <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-4 font-black">Teléfono de Enlace</label>
                        <input type="tel" name="telefono" value={usuario?.telefono} maxlength="15" required placeholder="55 0000 0000" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl focus:ring-1 focus:ring-orange-500 outline-none transition-all text-sm font-bold text-stone-900 dark:text-white" />
                    </div>

                    <div>
                        <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-4 font-black">Código Postal</label>
                        <input type="text" name="cp" maxlength="5" value={usuario?.codigoPostal} required placeholder="00000" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl focus:ring-1 focus:ring-orange-500 outline-none transition-all text-sm font-bold text-stone-900 dark:text-white font-mono" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-4 font-black">Dirección de Envío Completa</label>
                        <input type="text" name="direccion" value={usuario?.direccion} required placeholder="Calle, Número, Colonia..." class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl focus:ring-1 focus:ring-orange-500 outline-none transition-all text-sm font-bold text-stone-900 dark:text-white" />
                    </div>

                    <div>
                        <label class="block text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-4 font-black">Entidad Federativa</label>
                        <div class="relative">
                            <select name="estado" class="w-full bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 p-5 rounded-2xl focus:ring-1 focus:ring-orange-500 outline-none transition-all text-sm font-bold text-stone-900 dark:text-white appearance-none cursor-pointer">
                                <option value="CDMX" selected={usuario?.estado === 'CDMX'}>Ciudad de México</option>
                                <option value="Edomex" selected={usuario?.estado === 'Edomex'}>Estado de México</option>
                            </select>
                            <span class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none opacity-50">▼</span>
                        </div>
                    </div>

                    <div class="md:col-span-2 pt-6 flex justify-center md:justify-start">
                        <button type="submit" class="w-full md:w-auto bg-stone-900 dark:bg-white text-white dark:text-black font-black py-5 px-14 rounded-full hover:bg-orange-600 hover:dark:bg-orange-600 hover:text-white transition-all uppercase text-[10px] tracking-[0.3em] shadow-2xl active:scale-95 cursor-pointer">
                            Actualizar Credencial
                        </button>
                    </div>
                </div>
            </form>
        </section>

        <section>
            <div class="mb-16 border-b border-stone-200 dark:border-stone-800 pb-8 flex items-end justify-between">
                <h2 class="text-4xl md:text-5xl font-serif italic font-black text-stone-900 dark:text-white tracking-tight">Bitácora de Pedidos</h2>
                <span class="text-stone-400 font-black text-[10px] uppercase tracking-widest mb-2">{ordenes.length} Registros</span>
            </div>

            {ordenes.length === 0 ? (
                <div class="p-20 text-center border-2 border-dashed border-stone-200 dark:border-stone-800 rounded-[50px] transition-colors">
                    <p class="text-stone-500 dark:text-stone-400 font-serif italic text-lg">"Aún no se registran expediciones en tu historial personal."</p>
                    <a href="/tienda/chocolates" class="inline-block mt-8 text-[10px] font-black uppercase tracking-[0.3em] text-orange-600 hover:text-orange-500 transition-colors border-b-2 border-orange-600 pb-1">Iniciar primera compra</a>
                </div>
            ) : (
                <div class="space-y-8">
                    {ordenes.map(orden => {
                        const tieneBoletos = orden.detalles.length === 0 && orden.total > 0;

                        return (
                            <div class="bg-white dark:bg-[#110e0d] border border-stone-200 dark:border-stone-800 p-8 md:p-10 rounded-[40px] flex flex-col lg:flex-row justify-between gap-10 hover:border-orange-500/50 transition-all shadow-xl group duration-500">
                                <div class="flex-grow space-y-4">
                                    <div class="flex flex-wrap items-center gap-4">
                                        <span class="bg-stone-50 dark:bg-[#0c0a09] border border-stone-200 dark:border-stone-800 px-4 py-1.5 rounded-full text-[10px] font-mono font-black text-stone-500 uppercase tracking-widest">
                                            #{orden.id.slice(-6).toUpperCase()}
                                        </span>
                                        <span class="text-xs text-stone-400 font-bold uppercase tracking-wider">
                                            {new Date(orden.fecha).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' })}
                                        </span>
                                    </div>

                                    <div class="space-y-2">
                                        {orden.detalles.map(det => (
                                            <p class="text-lg text-stone-700 dark:text-stone-300 font-serif italic flex items-center gap-3">
                                                <span class="font-sans font-black text-xs text-orange-500 opacity-60">• {det.cantidad}x</span> 
                                                {det.chocolate?.nombre}
                                            </p>
                                        ))}
                                        {tieneBoletos && (
                                            <div class="inline-flex items-center gap-2 bg-orange-600/10 text-orange-600 dark:text-orange-400 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest mt-2 border border-orange-600/20">
                                                <span>🎫</span> Accesos Digitales
                                            </div>
                                        )}
                                    </div>
                                </div>

                                <div class="lg:text-right flex flex-row lg:flex-col items-center lg:items-end justify-between lg:justify-center border-t lg:border-t-0 lg:border-l border-stone-100 dark:border-stone-800 pt-8 lg:pt-0 lg:pl-12 transition-all duration-500">
                                    <div class="mb-0 lg:mb-4">
                                        <span class="text-[9px] text-stone-400 uppercase tracking-[0.3em] block mb-1 font-black">Aporte Total</span>
                                        <span class="text-4xl font-black text-stone-900 dark:text-white font-mono tracking-tighter">${orden.total.toFixed(2)}</span>
                                    </div>
                                    <a href={`/ticket/${orden.id}`} class="bg-stone-900 dark:bg-white text-white dark:text-black px-8 py-3 rounded-full text-[9px] font-black uppercase tracking-[0.2em] hover:bg-orange-600 hover:text-white transition-all shadow-lg active:scale-95">
                                        Recibo 📄
                                    </a>
                                </div>
                            </div>
                        )
                    })}
                </div>
            )}
        </section>
    </div>
</Layout>